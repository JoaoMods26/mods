	-- Botón enviar
	local boton = Instance.new("TextButton", frame)
	boton.Size             = UDim2.new(1, -20, 0, 30)
	boton.Position         = UDim2.new(0, 10, 0, 195)
	boton.Text             = " Enviar a todos"
	boton.TextScaled       = true
	boton.BackgroundColor3 = Color3.fromRGB(60, 130, 255)
	boton.TextColor3       = Color3.new(1, 1, 1)
	Instance.new("UICorner", boton)

	boton.MouseButton1Click:Connect(function()
		local encabezado = encabezadoBox.Text
		if encabezado == "" then return end  -- No enviar sin encabezado

		local mensaje  = cajaMensaje.Text
		local duracion = tonumber(duracionBox.Text) or 6
		local posicion = posicionDropdown.Text
		local r        = tonumber(colorR.Text) or 109
		local g        = tonumber(colorG.Text) or 89
		local b        = tonumber(colorB.Text) or 122

		local data = {
			encabezado = encabezado,
			mensaje    = mensaje,
			duracion   = duracion,
			posicion   = posicion,
			color      = { r, g, b },
			timestamp  = os.time(),
			key        = claveSeguridad,
			fijar      = fijarNotificacion
		}

		local jsonData = HttpService:JSONEncode(data)
		local request  = (syn and syn.request) or (http and http.request) or request
		if request then
			request({
				Url     = firebaseURL,
				Method  = "PUT",
				Headers = { ["Content-Type"] = "application/json" },
				Body    = jsonData
			})
			-- Auto-borrar de Firebase si no está fijada
			if not fijarNotificacion then
				task.delay(duracion, function()
					request({ Url = firebaseURL, Method = "DELETE" })
				end)
			end
		end
	end)

	-- Tecla L para mostrar/ocultar panel (PC)
	game:GetService("UserInputService").InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then return end
		if input.KeyCode == Enum.KeyCode.L then
			frame.Visible = not frame.Visible
		end
	end)
end

task.spawn(function()
	local request = (syn and syn.request) or (http and http.request) or request
	if not request then return end

	while true do
		task.wait(2.5)

		pcall(function()
			local response = request({ Url = firebaseURL, Method = "GET" })

			-- ✅ FIX: Validaciones estrictas antes de hacer cualquier cosa
			if not response then return end
			if response.StatusCode ~= 200 then return end
			if not response.Body then return end
			if response.Body == "null" then return end   -- Firebase vacío/borrado
			if response.Body == "" then return end       -- Respuesta vacía

			-- ✅ FIX: Parseo seguro del JSON
			local ok, data = pcall(function()
				return HttpService:JSONDecode(response.Body)
			end)
			if not ok then return end                        -- JSON inválido
			if type(data) ~= "table" then return end         -- No es objeto

			-- ✅ FIX: Sin encabezado = no mostrar nada
			if not data.encabezado or data.encabezado == "" then return end

			-- ✅ FIX: Sin timestamp nuevo = ya fue mostrada
			if not data.timestamp then return end
			if data.timestamp == ultimoTimestamp then return end

			-- Llegamos aquí solo si hay datos válidos y nuevos
			ultimoTimestamp = data.timestamp

			-- Limpiar notificaciones anteriores
			for _, gui in ipairs(guiParent:GetChildren()) do
				if gui.Name == "JmodsNotificacionVisual" then
					gui:Destroy()
				end
			end

			-- Crear GUI de notificación
			local notifGui   = Instance.new("ScreenGui", guiParent)
			notifGui.Name    = "JmodsNotificacionVisual"

			local notifFrame = Instance.new("Frame", notifGui)
			notifFrame.Size                = UDim2.new(0, 320, 0, 60)
			notifFrame.BackgroundTransparency = 0.45
			notifFrame.BorderSizePixel     = 0
			notifFrame.ClipsDescendants    = true
			Instance.new("UICorner", notifFrame)

			-- Posición de la notificación
			local pos = data.posicion or "Arriba Derecha"
			if pos == "Arriba Derecha" then
				notifFrame.Position = UDim2.new(1, -340, 0, 10)
			elseif pos == "Arriba izquierda" then
				notifFrame.Position = UDim2.new(0, 10, 0, 10)
			elseif pos == "Abajo derecha" then
				notifFrame.Position = UDim2.new(1, -340, 1, -70)
			elseif pos == "Abajo izquierda" then
				notifFrame.Position = UDim2.new(0, 10, 1, -70)
			elseif pos == "En medio" then
				notifFrame.Position = UDim2.new(0.5, -160, 0.5, -30)
			end

			-- Color del fondo (rainbow o RGB)
			if data.rainbow then
				task.spawn(function()
					local h = 0
					while notifFrame.Parent do
						h = (h + 0.01) % 1
						notifFrame.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
						task.wait(0.05)
					end
				end)
			else
				notifFrame.BackgroundColor3 = Color3.fromRGB(
					table.unpack(data.color or { 109, 89, 122 })
				)
			end

			-- Ícono decorativo
			local icon = Instance.new("TextLabel", notifFrame)
			icon.Size                 = UDim2.new(0, 30, 0, 30)
			icon.Position             = UDim2.new(0, 10, 0, 15)
			icon.BackgroundTransparency = 1
			icon.Text                 = "✨"
			icon.TextSize             = 20
			icon.Font                 = Enum.Font.GothamBold
			icon.TextColor3           = Color3.new(1, 1, 1)

			-- Encabezado de la notificación
			local encabezadoLabel = Instance.new("TextLabel", notifFrame)
			encabezadoLabel.Size                 = UDim2.new(1, -50, 0, 20)
			encabezadoLabel.Position             = UDim2.new(0, 50, 0, 10)
			encabezadoLabel.Text                 = data.encabezado
			encabezadoLabel.TextColor3           = Color3.fromRGB(255, 255, 255)
			encabezadoLabel.Font                 = Enum.Font.GothamBold
			encabezadoLabel.TextSize             = 16
			encabezadoLabel.BackgroundTransparency = 1
			encabezadoLabel.TextXAlignment       = Enum.TextXAlignment.Left

			-- ── Procesado de mensaje con soporte de links ────────────────
			local mensajeOriginal = data.mensaje or ""
			local yOffset         = 30

			local function crearLabel(texto, clickableUrl)
				local label
				if clickableUrl then
					label      = Instance.new("TextButton")
					label.Text = "🔗 " .. texto
					label.TextColor3 = Color3.fromRGB(0, 170, 255)
					local function abrirLink()
						if setclipboard then setclipboard(clickableUrl) end
						if syn and syn.open_url then
							syn.open_url(clickableUrl)
						elseif getgenv and getgenv().openurl then
							getgenv().openurl(clickableUrl)
						end
					end
					label.MouseButton1Click:Connect(abrirLink)
					label.TouchTap:Connect(abrirLink)
				else
					label            = Instance.new("TextLabel")
					label.Text       = texto
					label.TextColor3 = Color3.fromRGB(200, 200, 200)
				end

				label.Size                 = UDim2.new(1, -50, 0, 20)
				label.Position             = UDim2.new(0, 50, 0, yOffset)
				label.BackgroundTransparency = 1
				label.Font                 = Enum.Font.Gotham
				label.TextSize             = 14
				label.TextXAlignment       = Enum.TextXAlignment.Left
				label.Parent               = notifFrame

				yOffset = yOffset + 20
			end

			local function nombreAmigableDeURL(url)
				if url:find("youtube") or url:find("youtu%.be") then return "YouTube"
				elseif url:find("roblox%.com")   then return "Roblox"
				elseif url:find("discord%.gg")   then return "Discord"
				elseif url:find("twitter%.com")  then return "Twitter"
				elseif url:find("tiktok%.com")   then return "TikTok"
				elseif url:find("github%.com")   then return "GitHub"
				elseif url:find("instagram%.com") then return "Instagram"
				elseif url:find("facebook%.com") then return "Facebook"
				else return "Link"
				end
			end

			-- Dividir el mensaje en texto plano y links clickeables
			local function procesarMensaje(msg)
				local lastEnd = 1
				for inicio, link, fin in msg:gmatch("()(https?://[%w%.%-%_/%?%=%&%#%+%%]+)()") do
					local textoPrevio = msg:sub(lastEnd, inicio - 1)
					if textoPrevio ~= "" then
						crearLabel(textoPrevio, nil)
					end
					crearLabel(nombreAmigableDeURL(link), link)
					lastEnd = fin
				end
				local textoFinal = msg:sub(lastEnd)
				if textoFinal ~= "" then
					crearLabel(textoFinal, nil)
				end
			end

			procesarMensaje(mensajeOriginal)

			-- Auto-destruir después de la duración
			if not data.fijar then
				task.delay(data.duracion or 6, function()
					if notifGui and notifGui.Parent then
						notifGui:Destroy()
					end
				end)
			end
		end)
	end
end)
