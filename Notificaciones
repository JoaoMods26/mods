-- ============================================================
--  POSICION CORREGIDA: usa ViewportSize para pixeles exactos.
--  El bug anterior usaba escala UDim2 (0-1) que varia segun
--  pantalla y el inset del topbar causaba desplazamiento.
-- ============================================================
local function getPosUDim2(posId, frameW, frameH)
	local cam = workspace.CurrentCamera
	local vp  = cam and cam.ViewportSize or Vector2.new(1280, 720)
	local SW, SH = vp.X, vp.Y
	frameW = frameW or 340
	frameH = frameH or 80
	local pad = 12
	if     posId == "top_right"    then return UDim2.fromOffset(SW - frameW - pad, pad)
	elseif posId == "top_left"     then return UDim2.fromOffset(pad, pad)
	elseif posId == "bottom_right" then return UDim2.fromOffset(SW - frameW - pad, SH - frameH - pad)
	elseif posId == "bottom_left"  then return UDim2.fromOffset(pad, SH - frameH - pad)
	elseif posId == "center"       then return UDim2.fromOffset((SW - frameW) / 2, (SH - frameH) / 2)
	else                                return UDim2.fromOffset(SW - frameW - pad, pad)
	end
end

local function addCorner(p, r)
	local c = Instance.new("UICorner", p); c.CornerRadius = UDim.new(0, r or 8); return c
end
local function addStroke(p, col, thick, trans)
	local s = Instance.new("UIStroke", p)
	s.Color = col or Color3.fromRGB(80,80,80)
	s.Thickness = thick or 1
	s.Transparency = trans or 0
	return s
end
local function addGradient(p, cA, cB, rot)
	local g = Instance.new("UIGradient", p)
	g.Color = ColorSequence.new(cA, cB)
	g.Rotation = rot or 90
	return g
end
local function tw(obj, props, t, style)
	TweenService:Create(obj, TweenInfo.new(t or 0.22, style or Enum.EasingStyle.Quart, Enum.EasingDirection.Out), props):Play()
end

local function actualizarDuenos()
	pcall(function()
		local req = (syn and syn.request) or (http and http.request) or request
		if not req then return end
		local res = req({ Url = duenosURL, Method = "GET" })
		if res and res.Body then
			table.clear(duenos)
			for nombre in res.Body:gmatch("[^\r\n]+") do duenos[nombre] = true end
		end
	end)
end
