local function getPosUDim2(posId, frameW, frameH)
	frameW = frameW or 340
	frameH = frameH or 80
	local pad = 12
	if     posId == "top_right"    then return UDim2.new(1, -(frameW + pad), 0, pad)
	elseif posId == "top_left"     then return UDim2.new(0, pad, 0, pad)
	elseif posId == "bottom_right" then return UDim2.new(1, -(frameW + pad), 1, -(frameH + pad))
	elseif posId == "bottom_left"  then return UDim2.new(0, pad, 1, -(frameH + pad))
	elseif posId == "center"       then return UDim2.new(0.5, -(frameW/2), 0.5, -(frameH/2))
	else                                return UDim2.new(1, -(frameW + pad), 0, pad)
	end
end

--  Helpers UI
local function addCorner(p, r)
	local c = Instance.new("UICorner", p)
	c.CornerRadius = UDim.new(0, r or 8)
	return c
end

local function addStroke(p, col, thick, trans)
	local s = Instance.new("UIStroke", p)
	s.Color        = col   or Color3.fromRGB(80,80,80)
	s.Thickness    = thick or 1
	s.Transparency = trans or 0
	return s
end

local function addGradient(p, cA, cB, rot)
	local g = Instance.new("UIGradient", p)
	g.Color    = ColorSequence.new(cA, cB)
	g.Rotation = rot or 90
	return g
end

local function tw(obj, props, t, style)
	TweenService:Create(obj, TweenInfo.new(
		t or 0.22,
		style or Enum.EasingStyle.Quart,
		Enum.EasingDirection.Out
	), props):Play()
end

--  Cargar dueños
local function actualizarDuenos()
	pcall(function()
		local req = (syn and syn.request) or (http and http.request) or request
		if not req then return end
		local res = req({ Url = duenosURL, Method = "GET" })
		if res and res.Body then
			table.clear(duenos)
			for nombre in res.Body:gmatch("[^\r\n]+") do
				duenos[nombre] = true
			end
		end
	end)
end

actualizarDuenos()
task.spawn(function()
	while true do task.wait(400) actualizarDuenos() end
end)

