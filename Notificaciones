	titulo.BackgroundTransparency = 1
	titulo.Text               = " Enviar Notificación"
	titulo.TextColor3         = Color3.fromRGB(255, 255, 255)
	titulo.Font               = Enum.Font.GothamBold
	titulo.TextSize           = 16

	-- Campo: Encabezado
	local encabezadoBox = Instance.new("TextBox", frame)
