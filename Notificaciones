	if not req then return end

	while true do
		task.wait(2.5)
		pcall(function()
			local res = req({ Url = firebaseURL, Method = "GET" })
			if not res or res.StatusCode ~= 200 then return end
			if not res.Body or res.Body == "null" or res.Body == "" then return end

			local ok, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
			if not ok or type(data) ~= "table" then return end
			if not data.encabezado or data.encabezado == "" then return end
			if not data.timestamp  or data.timestamp == ultimoTimestamp then return end
			ultimoTimestamp = data.timestamp

			-- Limpiar anteriores
			for _, g in ipairs(guiParent:GetChildren()) do
				if g.Name == "JmodsNotificacionVisual" then g:Destroy() end
			end

			-- Calcular altura
			local msg        = data.mensaje or ""
			local lineas     = 1
			for _ in msg:gmatch("https?://[%w%.%-%_/%?%=%&%#%+%%]+") do lineas += 1 end
			local altH       = math.max(72, 52 + lineas * 20)

			local notifGui   = Instance.new("ScreenGui", guiParent)
			notifGui.Name    = "JmodsNotificacionVisual"
			notifGui.ResetOnSpawn  = false
			notifGui.ZIndexBehavior = Enum.ZIndexBehavior.Global

			local nFrame = Instance.new("Frame", notifGui)
			nFrame.Size                = UDim2.new(0, 340, 0, altH)
			nFrame.BackgroundTransparency = 0.1
			nFrame.BorderSizePixel     = 0
			nFrame.ClipsDescendants    = true
			addCorner(nFrame, 10)

			-- Posición
			local posId = data.posicion or "top_right"
			nFrame.Position = getPosUDim2(posId, 340, altH)
			local posInicial = nFrame.Position

			-- Animación entrada
			if posId == "top_right" or posId == "bottom_right" then
				nFrame.Position = posInicial + UDim2.new(0, 370, 0, 0)
			elseif posId == "top_left" or posId == "bottom_left" then
				nFrame.Position = posInicial + UDim2.new(0, -370, 0, 0)
			else
				nFrame.BackgroundTransparency = 1
				TweenService:Create(nFrame, TweenInfo.new(0.35), { BackgroundTransparency = 0.1 }):Play()
			end
			if posId ~= "center" then
				TweenService:Create(nFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Position = posInicial }):Play()
			end

			-- Accent lateral
			local accent = Instance.new("Frame", nFrame)
			accent.Size            = UDim2.new(0, 4, 1, 0)
			accent.BorderSizePixel = 0
			addCorner(accent, 4)

			-- Color
			local cr = (data.color and data.color[1]) or 100
			local cg = (data.color and data.color[2]) or 140
			local cb = (data.color and data.color[3]) or 255

			if data.rainbow then
				task.spawn(function()
					local h = 0
					while nFrame.Parent do
						h = (h + 0.01) % 1
						nFrame.BackgroundColor3 = Color3.fromHSV(h, 0.65, 0.85)
						accent.BackgroundColor3 = Color3.fromHSV((h+0.5)%1, 1, 1)
						task.wait(0.05)
					end
				end)
			else
				nFrame.BackgroundColor3 = Color3.fromRGB(
					math.clamp(cr - 25, 0, 255),
					math.clamp(cg - 25, 0, 255),
					math.clamp(cb - 25, 0, 255)
				)
				accent.BackgroundColor3 = Color3.fromRGB(cr, cg, cb)
			end

			addStroke(nFrame, Color3.fromRGB(80, 80, 115), 1, 0.25)

			-- Ícono
			local icon = Instance.new("TextLabel", nFrame)
			icon.Size                  = UDim2.new(0, 26, 0, 26)
			icon.Position              = UDim2.new(0, 12, 0, 12)
			icon.BackgroundTransparency = 1
			icon.Text                  = "*"
			icon.TextSize              = 18
			icon.Font                  = Enum.Font.GothamBold
			icon.TextColor3            = Color3.fromRGB(255, 255, 255)

			-- Encabezado
			local encLbl = Instance.new("TextLabel", nFrame)
			encLbl.Size                  = UDim2.new(1, -52, 0, 20)
			encLbl.Position              = UDim2.new(0, 46, 0, 10)
			encLbl.Text                  = data.encabezado
			encLbl.TextColor3            = Color3.fromRGB(255, 255, 255)
			encLbl.Font                  = Enum.Font.GothamBold
			encLbl.TextSize              = 14
			encLbl.BackgroundTransparency = 1
			encLbl.TextXAlignment        = Enum.TextXAlignment.Left
			encLbl.TextTruncate          = Enum.TextTruncate.AtEnd

			-- Mensaje con links
			local yOff = 32
			local function crearLinea(texto, url)
				local lbl
				if url then
					lbl = Instance.new("TextButton", nFrame)
					lbl.Text      = "[URL] " .. texto
					lbl.TextColor3 = Color3.fromRGB(120, 185, 255)
					lbl.BackgroundTransparency = 1
					lbl.AutoButtonColor = false
					local function open()
						if setclipboard then setclipboard(url) end
						if syn and syn.open_url then syn.open_url(url)
						elseif getgenv and getgenv().openurl then getgenv().openurl(url) end
					end
					lbl.MouseButton1Click:Connect(open)
					lbl.TouchTap:Connect(open)
				else
					lbl = Instance.new("TextLabel", nFrame)
					lbl.Text      = texto
					lbl.TextColor3 = Color3.fromRGB(210, 210, 225)
					lbl.BackgroundTransparency = 1
				end
				lbl.Size           = UDim2.new(1, -52, 0, 18)
				lbl.Position       = UDim2.new(0, 46, 0, yOff)
				lbl.Font           = Enum.Font.Gotham
				lbl.TextSize       = 13
				lbl.TextXAlignment = Enum.TextXAlignment.Left
				lbl.TextTruncate   = Enum.TextTruncate.AtEnd
				yOff += 20
			end

			local function nombreAmigable(url)
				if url:find("youtube") or url:find("youtu%.be") then return "YouTube"
				elseif url:find("roblox%.com")    then return "Roblox"
				elseif url:find("discord%.gg")    then return "Discord"
				elseif url:find("twitter%.com")   then return "Twitter / X"
				elseif url:find("tiktok%.com")    then return "TikTok"
				elseif url:find("github%.com")    then return "GitHub"
				elseif url:find("instagram%.com") then return "Instagram"
				elseif url:find("facebook%.com")  then return "Facebook"
				else return "Link"
				end
			end

			local lastE = 1
			for ini, link, fin in msg:gmatch("()(https?://[%w%.%-%_/%?%=%&%#%+%%]+)()") do
				local prev = msg:sub(lastE, ini - 1)
				if prev ~= "" then crearLinea(prev, nil) end
				crearLinea(nombreAmigable(link), link)
				lastE = fin
			end
			local resto = msg:sub(lastE)
			if resto ~= "" then crearLinea(resto, nil) end

			-- Barra de progreso
			-- FIX: forzar numero para evitar que string rompa task.delay/TweenInfo
			local fijarFlag = (data.fijar == true)
			if not fijarFlag then
				local dur = tonumber(data.duracion) or 6

				local pBg = Instance.new("Frame", nFrame)
				pBg.Size             = UDim2.new(1, -10, 0, 3)
				pBg.Position         = UDim2.new(0, 5, 1, -5)
				pBg.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
				pBg.BorderSizePixel  = 0
				addCorner(pBg, 2)

				local pFill = Instance.new("Frame", pBg)
				pFill.Size             = UDim2.new(1, 0, 1, 0)
				pFill.BackgroundColor3 = accent.BackgroundColor3
				pFill.BorderSizePixel  = 0
				addCorner(pFill, 2)

				TweenService:Create(pFill, TweenInfo.new(dur, Enum.EasingStyle.Linear), {
					Size = UDim2.new(0, 0, 1, 0)
				}):Play()

				-- Salida animada
				task.delay(dur - 0.3, function()
					if not nFrame or not nFrame.Parent then return end
					if posId == "top_right" or posId == "bottom_right" then
						TweenService:Create(nFrame, TweenInfo.new(0.28), {
							Position = posInicial + UDim2.new(0, 380, 0, 0)
						}):Play()
					elseif posId == "top_left" or posId == "bottom_left" then
						TweenService:Create(nFrame, TweenInfo.new(0.28), {
							Position = posInicial + UDim2.new(0, -380, 0, 0)
						}):Play()
					else
						TweenService:Create(nFrame, TweenInfo.new(0.28), {
							BackgroundTransparency = 1
						}):Play()
					end
				end)

				-- Destroy principal - usa pcall para que nunca falle silenciosamente
				local durNum = dur  -- capturar en closure
				task.delay(durNum, function()
					pcall(function()
						if notifGui and notifGui.Parent then
							notifGui:Destroy()
						end
					end)
				end)
			end
		end)
	end
end)
