-- =============================================================
--  FUNCION REUTILIZABLE: construir frame de notificacion
--  v2.7: altura dinamica real usando TextService:GetTextSize
--        TextWrapped = true, sin truncado.
-- =============================================================
local function construirNotifFrame(parent, data, zBase)
	zBase = zBase or 1
	local msg   = data.mensaje    or ""
	local enc   = data.encabezado or ""
	local posId = data.posicion   or "top_right"
	local dur   = tonumber(data.duracion) or 6
	local cr    = (data.color and data.color[1]) or 100
	local cg    = (data.color and data.color[2]) or 140
	local cb    = (data.color and data.color[3]) or 255

	-- Ancho disponible para texto: frame(340) - margenIzq(46) - margenDer(10)
	local LABEL_W  = 284
	local FONT     = Enum.Font.Gotham
	local FSIZE    = 13
	local LINE_PAD = 3  -- separacion entre lineas de texto

	local function nombreAmigable(url)
		if     url:find("youtube")      or url:find("youtu%.be")  then return "YouTube"
		elseif url:find("roblox%.com")                             then return "Roblox"
		elseif url:find("discord%.gg")                             then return "Discord"
		elseif url:find("twitter%.com")                            then return "Twitter / X"
		elseif url:find("tiktok%.com")                             then return "TikTok"
		elseif url:find("github%.com")                             then return "GitHub"
		elseif url:find("instagram%.com")                          then return "Instagram"
		elseif url:find("facebook%.com")                           then return "Facebook"
		else return "Link" end
	end

	-- Calcula la altura real que necesita un texto al hacer wrap
	local function textoAltura(texto, prefijo)
		local t = (prefijo or "") .. texto
		if t == "" then return FSIZE end
		local ok, sz = pcall(function()
			return TextService:GetTextSize(t, FSIZE, FONT, Vector2.new(LABEL_W, 9999))
		end)
		if ok and sz then return math.max(FSIZE, sz.Y) end
		-- Fallback por si TextService no esta disponible
		local charsPerLine = math.floor(LABEL_W / (FSIZE * 0.56))
		return math.max(FSIZE, math.ceil(math.max(1, #t) / charsPerLine) * (FSIZE + 2))
	end

	-- Construir lista de segmentos antes de crear la UI para pre-calcular altura
	local segmentos = {}  -- { texto, url, altura }
	local lastE = 1
	for ini, link, fin in msg:gmatch("()(https?://[%w%.%-%_/%?%=%&%#%+%%]+)()") do
		local prev = msg:sub(lastE, ini-1)
		if prev ~= "" then
			table.insert(segmentos, { texto=prev,                 url=nil,  h=textoAltura(prev)         })
		end
		local nombre = nombreAmigable(link)
		table.insert(segmentos,     { texto=nombre, urlReal=link, url=link, h=textoAltura(nombre,"[Link] ") })
		lastE = fin
	end
	local resto = msg:sub(lastE)
	if resto ~= "" then
		table.insert(segmentos, { texto=resto, url=nil, h=textoAltura(resto) })
	end
	if #segmentos == 0 then
		table.insert(segmentos, { texto="", url=nil, h=FSIZE })
	end

	-- Altura total del encabezado (puede ser largo tambien)
	local encH = textoAltura(enc, nil)
	encH = math.max(22, encH)

	-- Sumar todo: margen superior + encabezado + separador + contenido + barra progreso
	local yStart = 8 + encH + 6  -- posY inicial del primer segmento
	local contentH = 0
	for _, seg in ipairs(segmentos) do
		contentH += seg.h + LINE_PAD
	end
	local altH = math.max(80, yStart + contentH + 14)  -- 14 = barra + padding

	-- ── Crear el frame ───────────────────────────────────────
	local nFrame = Instance.new("Frame", parent)
	nFrame.Size = UDim2.new(0, 340, 0, altH)
	nFrame.BackgroundTransparency = 0.08
	nFrame.BorderSizePixel = 0
	nFrame.ZIndex = zBase
	addCorner(nFrame, 10)

	local posInicial = getPosUDim2(posId, 340, altH)
	nFrame.Position  = posInicial

	nFrame.BackgroundColor3 = Color3.fromRGB(
		math.clamp(cr-25,0,255), math.clamp(cg-25,0,255), math.clamp(cb-25,0,255)
	)
	addStroke(nFrame, Color3.fromRGB(80,80,115), 1, 0.25)

	local accent = Instance.new("Frame", nFrame)
	accent.Size = UDim2.new(0,4,1,0)
	accent.BackgroundColor3 = Color3.fromRGB(cr,cg,cb)
	accent.BorderSizePixel = 0; accent.ZIndex = zBase+1; addCorner(accent, 4)

	local icon = Instance.new("TextLabel", nFrame)
	icon.Size = UDim2.new(0,26,0,26); icon.Position = UDim2.new(0,12,0,8)
	icon.BackgroundTransparency = 1; icon.Text = "*"
	icon.TextSize = 18; icon.Font = Enum.Font.GothamBold
	icon.TextColor3 = Color3.fromRGB(cr,cg,cb); icon.ZIndex = zBase+2

	-- Encabezado con wrap si es largo
	local encLbl = Instance.new("TextLabel", nFrame)
	encLbl.Size = UDim2.new(1,-52,0,encH)
	encLbl.Position = UDim2.new(0,46,0,8)
	encLbl.Text = enc
	encLbl.TextColor3 = Color3.fromRGB(255,255,255)
	encLbl.Font = Enum.Font.GothamBold; encLbl.TextSize = 14
	encLbl.BackgroundTransparency = 1
	encLbl.TextXAlignment = Enum.TextXAlignment.Left
	encLbl.TextWrapped = true
	encLbl.TextTruncate = Enum.TextTruncate.None
	encLbl.ZIndex = zBase+2

	local sep = Instance.new("Frame", nFrame)
	sep.Size = UDim2.new(1,-52,0,1)
	sep.Position = UDim2.new(0,46,0, 8 + encH + 2)
	sep.BackgroundColor3 = Color3.fromRGB(cr,cg,cb)
	sep.BackgroundTransparency = 0.7
	sep.BorderSizePixel = 0; sep.ZIndex = zBase+1

	-- Crear labels para cada segmento con altura calculada
	local yOff = yStart
	for _, seg in ipairs(segmentos) do
		local lbl
		if seg.url then
			lbl = Instance.new("TextButton", nFrame)
			lbl.Text = "[Link] " .. seg.texto
			lbl.TextColor3 = Color3.fromRGB(130,195,255)
			lbl.BackgroundTransparency = 1; lbl.AutoButtonColor = false
			local u = seg.urlReal or seg.url
			local function open()
				if setclipboard then setclipboard(u) end
				if syn and syn.open_url then syn.open_url(u)
				elseif getgenv and getgenv().openurl then getgenv().openurl(u) end
			end
			lbl.MouseButton1Click:Connect(open); lbl.TouchTap:Connect(open)
		else
			lbl = Instance.new("TextLabel", nFrame)
			lbl.Text = seg.texto
			lbl.TextColor3 = Color3.fromRGB(215,215,230)
			lbl.BackgroundTransparency = 1
		end
		lbl.Size = UDim2.new(1,-56, 0, seg.h)
		lbl.Position = UDim2.new(0,46,0,yOff)
		lbl.Font = FONT; lbl.TextSize = FSIZE
		lbl.TextXAlignment = Enum.TextXAlignment.Left
		lbl.TextWrapped = true                         -- texto con wrap
		lbl.TextTruncate = Enum.TextTruncate.None      -- sin corte
		lbl.ZIndex = zBase+2
		yOff += seg.h + LINE_PAD
	end

	local pBg = Instance.new("Frame", nFrame)
	pBg.Size = UDim2.new(1,-10,0,3); pBg.Position = UDim2.new(0,5,1,-5)
	pBg.BackgroundColor3 = Color3.fromRGB(30,30,50)
	pBg.BorderSizePixel = 0; pBg.ZIndex = zBase+1; addCorner(pBg,2)

	local pFill = Instance.new("Frame", pBg)
	pFill.Size = UDim2.new(1,0,1,0)
	pFill.BackgroundColor3 = Color3.fromRGB(cr,cg,cb)
	pFill.BorderSizePixel = 0; pFill.ZIndex = zBase+2; addCorner(pFill,2)

	-- Animacion de entrada
	if posId == "top_right" or posId == "bottom_right" then
		nFrame.Position = UDim2.fromOffset(posInicial.X.Offset + 380, posInicial.Y.Offset)
		TweenService:Create(nFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position=posInicial}):Play()
	elseif posId == "top_left" or posId == "bottom_left" then
		nFrame.Position = UDim2.fromOffset(posInicial.X.Offset - 380, posInicial.Y.Offset)
		TweenService:Create(nFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position=posInicial}):Play()
	else
		nFrame.BackgroundTransparency = 1
		TweenService:Create(nFrame, TweenInfo.new(0.35), {BackgroundTransparency=0.08}):Play()
	end

	return nFrame, pFill, posInicial, posId, dur
end

