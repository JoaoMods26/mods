	if not req then return end

	while true do
		task.wait(2.5)
		pcall(function()
			local res = req({ Url = firebaseURL, Method = "GET" })
			if not res or res.StatusCode ~= 200 then return end
			if not res.Body or res.Body == "null" or res.Body == "" then return end

			local ok, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
			if not ok or type(data) ~= "table" then return end
			if not data.encabezado or data.encabezado == "" then return end
			if not data.timestamp  or data.timestamp == ultimoTimestamp then return end
			ultimoTimestamp = data.timestamp

			for _, g in ipairs(guiParent:GetChildren()) do
				if g.Name == "JmodsNotificacionVisual" then g:Destroy() end
			end

			local msg        = data.mensaje or ""
			local lineas     = 1
			for _ in msg:gmatch("https?://[%w%.%-%_/%?%=%&%#%+%%]+") do lineas += 1 end
			local altH       = math.max(72, 52 + lineas * 20)

