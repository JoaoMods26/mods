		colorPreviewBig.BackgroundColor3 = col
		hexLbl.Text = hexFromRGB(currentR, currentG, currentB)

		-- Contraste del texto hex
		local lum = 0.299*col.R + 0.587*col.G + 0.114*col.B
		hexLbl.TextColor3 = lum > 0.5 and Color3.fromRGB(30,30,30) or Color3.new(1,1,1)

		-- Actualizar RGB inputs (sin disparar sus callbacks)
		colorR.Text = tostring(currentR)
		colorG.Text = tostring(currentG)
