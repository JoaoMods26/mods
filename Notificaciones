	end

	-- Actualizar picker desde RGB inputs
	local function applyRGB(r, g, b)
		local h, s, v = Color3.fromRGB(r, g, b):ToHSV()
		applyHSV(h, s, v)
	end

	-- Inicializar
	applyHSV(currentH, currentS, currentV)

	-- Helpers para posición relativa dentro de un frame
	local function getRelative(frame, absPos)
		local fPos = frame.AbsolutePosition
		local fSiz = frame.AbsoluteSize
		local x = math.clamp((absPos.X - fPos.X) / fSiz.X, 0, 1)
		local y = math.clamp((absPos.Y - fPos.Y) / fSiz.Y, 0, 1)
		return x, y
	end

	-- SV Box input
	local function onSVInput(pos)
		local x, y = getRelative(svBox, pos)
		applyHSV(currentH, x, 1 - y)
	end

	local function onHueInput(pos)
		local _, y = getRelative(hueBar, pos)
		applyHSV(y, currentS, currentV)
	end

