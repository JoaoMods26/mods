	sendBtn.Size=UDim2.new(1,0,1,0); sendBtn.BackgroundColor3=Color3.fromRGB(60,120,255)
	sendBtn.TextColor3=Color3.new(1,1,1); sendBtn.Font=Enum.Font.GothamBold
	sendBtn.TextSize=esMobil and 14 or 13; sendBtn.Text="ENVIAR A TODOS"
	sendBtn.BorderSizePixel=0; sendBtn.AutoButtonColor=false
	addCorner(sendBtn,8); addGradient(sendBtn,Color3.fromRGB(70,130,255),Color3.fromRGB(110,70,230))
	sendBtn.MouseEnter:Connect(function() tw(sendBtn,{BackgroundColor3=Color3.fromRGB(80,145,255)}) end)
	sendBtn.MouseLeave:Connect(function() tw(sendBtn,{BackgroundColor3=Color3.fromRGB(60,120,255)}) end)

	local enviandoLock=false
	local function feedbackEnviar(ok)
		if ok then
			sendBtn.Text="OK  ENVIADO!"; tw(sendBtn,{BackgroundColor3=Color3.fromRGB(40,175,80)})
		else
			sendBtn.Text="! ENCABEZADO REQUERIDO"; tw(sendBtn,{BackgroundColor3=Color3.fromRGB(200,55,55)})
		end
		task.delay(2.2, function()
			sendBtn.Text="ENVIAR A TODOS"; tw(sendBtn,{BackgroundColor3=Color3.fromRGB(60,120,255)}); enviandoLock=false
		end)
	end

	sendBtn.MouseButton1Click:Connect(function()
		if enviandoLock then return end
		local enc = encabezadoBox.Text
		if enc=="" then feedbackEnviar(false); return end
		enviandoLock=true
		if previewGui and previewGui.Parent then previewGui:Destroy(); previewGui=nil end
		local data = {
			encabezado = enc,
			mensaje    = cajaMensaje.Text,
			duracion   = tonumber(duracionBox.Text) or 6,
			posicion   = posicionSeleccionada,        -- envia la posicion elegida
			color      = {currentR, currentG, currentB},
			timestamp  = os.time(),
			key        = claveSeguridad,
			fijar      = fijarNotificacion
		}
		local req = (syn and syn.request) or (http and http.request) or request
		if req then
			req({
				Url    = firebaseURL,
				Method = "PUT",
				Headers = {["Content-Type"] = "application/json"},
				Body   = HttpService:JSONEncode(data)
			})
			if not fijarNotificacion then
				task.delay(tonumber(duracionBox.Text) or 6, function()
					req({Url=firebaseURL, Method="DELETE"})
				end)
			end
			feedbackEnviar(true)
		else
			enviandoLock=false
		end
	end)

	-- Toggle panel con tecla L
	UserInput.InputBegan:Connect(function(input, gp)
		if gp then return end
		if input.KeyCode==Enum.KeyCode.L then frame.Visible=not frame.Visible end
	end)

	if esMobil then
		local toggleBtn=Instance.new("TextButton", screenGui)
		toggleBtn.Size=UDim2.new(0,46,0,46); toggleBtn.Position=UDim2.new(0,10,0,10)
		toggleBtn.BackgroundColor3=Color3.fromRGB(60,120,255)
		toggleBtn.Text="J"; toggleBtn.TextScaled=true; toggleBtn.TextColor3=Color3.new(1,1,1)
		toggleBtn.Active=true; toggleBtn.Draggable=true; toggleBtn.ZIndex=10
		addCorner(toggleBtn,11); addStroke(toggleBtn,Color3.fromRGB(80,140,255),2,0.2)
		addGradient(toggleBtn,Color3.fromRGB(70,130,255),Color3.fromRGB(110,70,230))
		toggleBtn.MouseButton1Click:Connect(function() frame.Visible=not frame.Visible end)
	end

end -- fin bloque duenos

-- =============================================================
--  RECEPTOR DE NOTIFICACIONES - todos los jugadores
-- =============================================================
task.spawn(function()
	local req=(syn and syn.request) or (http and http.request) or request
	if not req then return end
	while true do
		task.wait(2.5)
		pcall(function()
			local res=req({Url=firebaseURL, Method="GET"})
			if not res or res.StatusCode~=200 then return end
			if not res.Body or res.Body=="null" or res.Body=="" then return end
			local ok,data=pcall(function() return HttpService:JSONDecode(res.Body) end)
			if not ok or type(data)~="table" then return end
			if not data.encabezado or data.encabezado=="" then return end
			if not data.timestamp or data.timestamp==ultimoTimestamp then return end
			ultimoTimestamp=data.timestamp

			for _,g in ipairs(guiParent:GetChildren()) do
				if g.Name=="JmodsNotificacionVisual" then g:Destroy() end
			end

			local notifGui=Instance.new("ScreenGui", guiParent)
			notifGui.Name="JmodsNotificacionVisual"; notifGui.ResetOnSpawn=false
			notifGui.ZIndexBehavior=Enum.ZIndexBehavior.Global

			local nFrame,pFill,posInicial,posId,dur=construirNotifFrame(notifGui, data, 1)
			TweenService:Create(pFill, TweenInfo.new(dur, Enum.EasingStyle.Linear), {Size=UDim2.new(0,0,1,0)}):Play()

			task.delay(dur-0.3, function()
				if not nFrame or not nFrame.Parent then return end
				if posId=="top_right" or posId=="bottom_right" then
					TweenService:Create(nFrame, TweenInfo.new(0.28), {Position=UDim2.fromOffset(posInicial.X.Offset+380, posInicial.Y.Offset)}):Play()
				elseif posId=="top_left" or posId=="bottom_left" then
					TweenService:Create(nFrame, TweenInfo.new(0.28), {Position=UDim2.fromOffset(posInicial.X.Offset-380, posInicial.Y.Offset)}):Play()
				else
					TweenService:Create(nFrame, TweenInfo.new(0.28), {BackgroundTransparency=1}):Play()
				end
			end)
			task.delay(dur, function()
				if notifGui and notifGui.Parent then notifGui:Destroy() end
			end)
		end)
	end
end)
