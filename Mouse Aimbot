-- ── ESP Update ────────────────────────────────────────────────────────────
local espTimer = 0
local ESP_RATE = 0.03

local function UpdateESP(dt)
    espTimer = espTimer + dt
    if espTimer < ESP_RATE then return end
    espTimer = 0

    local anyESP = ESPEnabled or TraceEnabled or NameESPEnabled or HealthBarEnabled or DistanceESPEnabled
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local sizing = _G.ESPSizing or 0.5

    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end

        local e = ESPCache[player]
        if not e then continue end

        if TeamCheckEnabled and not isEnemy(player) then
            hidePlayerESP(player)
            continue
        end

        if not anyESP or not player.Character then
            hidePlayerESP(player)
            continue
        end

        local hrp  = player.Character:FindFirstChild("HumanoidRootPart")
        local head = player.Character:FindFirstChild("Head")
        if not hrp or not head then
            hidePlayerESP(player)
            continue
        end

        if DistanceCheckEnabled then
            local dist = getDistance(player)
            if dist > MaxDistance then
                hidePlayerESP(player)
                continue
            end
        end

        -- ── WALL CHECK para ESP (NUEVO) ───────────────────────────────────
        -- Si WallCheckESP está activo, ocultamos el ESP de jugadores
        -- que estén detrás de una pared. No afecta al aimbot en absoluto.
        if WallCheckESP then
            local checkPart = player.Character:FindFirstChild(TargetPart)
                           or player.Character:FindFirstChild("Head")
                           or hrp
            if not HasLineOfSight(checkPart) then
                hidePlayerESP(player)
                continue  -- Está detrás de una pared, no dibujamos su ESP
            end
        end
        -- ─────────────────────────────────────────────────────────────────

        local headPos, onHead = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.3, 0))
        local rootPos, onRoot = Camera:WorldToViewportPoint(hrp.Position  - Vector3.new(0, 0.3, 0))

        if not (onHead and onRoot) or headPos.Z <= 0 then
            hidePlayerESP(player)
            continue
        end

        local color  = getESPColor(player)
        local height = math.abs(headPos.Y - rootPos.Y)
        local width  = height * sizing
        local topLeft = Vector2.new(rootPos.X - width / 2, headPos.Y)

        if ESPEnabled then
            e.Outline.Position = topLeft - Vector2.new(1, 1)
            e.Outline.Size     = Vector2.new(width + 2, height + 2)
            e.Outline.Visible  = true

            e.Box.Position = topLeft
            e.Box.Size     = Vector2.new(width, height)
            e.Box.Color    = color
            e.Box.Visible  = true
        else
            e.Outline.Visible = false
            e.Box.Visible     = false
        end

        if TraceEnabled then
            -- ── WALL CHECK para Tracers (NUEVO) ──────────────────────────
            -- Toggle independiente: si está activo y hay pared, oculta solo
            -- el tracer de ese jugador sin afectar cajas, nombres ni aimbot.
            if WallCheckTracers then
                local checkPart = player.Character:FindFirstChild(TargetPart)
                               or player.Character:FindFirstChild("Head")
                               or hrp
                if not HasLineOfSight(checkPart) then
                    e.Tracer.Visible = false
                    goto continueTracer  -- salta solo el bloque del tracer
                end
            end
            -- ─────────────────────────────────────────────────────────────
            e.Tracer.From    = screenCenter
            e.Tracer.To      = Vector2.new(rootPos.X, rootPos.Y)
            e.Tracer.Color   = color
            e.Tracer.Visible = true
            ::continueTracer::
        else
            e.Tracer.Visible = false
        end

        if NameESPEnabled then
            e.NameLabel.Text     = player.DisplayName
            e.NameLabel.Position = Vector2.new(rootPos.X, headPos.Y - 16)
            e.NameLabel.Color    = color
            e.NameLabel.Visible  = true
        else
            e.NameLabel.Visible = false
        end

        if HealthBarEnabled then
            local hp, maxHp = getHealth(player)
            local ratio = math.clamp(hp / maxHp, 0, 1)
            local barW  = 4
            local barX  = topLeft.X - barW - 2

            e.HealthBg.Position = Vector2.new(barX, headPos.Y)
            e.HealthBg.Size     = Vector2.new(barW, height)
            e.HealthBg.Visible  = true

            e.HealthBar.Position = Vector2.new(barX, headPos.Y + height * (1 - ratio))
            e.HealthBar.Size     = Vector2.new(barW, height * ratio)
            e.HealthBar.Color    = Color3.fromRGB(
                math.floor(255 * (1 - ratio)),
                math.floor(255 * ratio),
                0
            )
            e.HealthBar.Visible = true
        else
            e.HealthBg.Visible  = false
            e.HealthBar.Visible = false
        end

        if DistanceESPEnabled then
            local dist = math.floor(getDistance(player))
            e.DistLabel.Text     = dist .. "m"
            e.DistLabel.Position = Vector2.new(rootPos.X, rootPos.Y + 4)
            e.DistLabel.Visible  = true
        else
            e.DistLabel.Visible = false
        end
    end
end

-- ── Aimbot ────────────────────────────────────────────────────────────────
local function IsReady(Character)
    if not Character then return false end
    local humanoid = Character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return false end
    local part = Character:FindFirstChild(TargetPart)
        or Character:FindFirstChild("Head")
        or Character:FindFirstChild("HumanoidRootPart")
    if not part then return false end
    local pos, visible = Camera:WorldToViewportPoint(part.Position)
    if not visible or pos.Z <= 0 then return false end
    return true, part, pos
end

local function PredictPosition(part)
    if not PredictionEnabled or not part or not part.Parent then return part.Position end
    local root = part.Parent:FindFirstChild("HumanoidRootPart")
    if not root then return part.Position end
    local vel = root.AssemblyLinearVelocity or root.Velocity
    return part.Position + vel * PredictionStrength
end

local currentTarget = nil
local targetLockTime = 0
local stickyLock = false

RunService.RenderStepped:Connect(function(dt)
    local mousePos = UserInputService:GetMouseLocation()

    FOVCircle.Position  = mousePos
    FOVCircle.Radius    = MouseFOV
    FOVCircle.Color     = RainbowMode and getRainbowColor() or FOVColor
    FOVCircle.Visible   = FOVEnabled

    UpdateESP(dt)

    if not AimbotEnabled or AimbotPaused then
        currentTarget = nil
        stickyLock    = false
        return
    end

    local closest     = nil
    local shortest    = math.huge
    local validTargets = {}

    for _, plr in pairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end

        if TeamCheckEnabled and not isEnemy(plr) then continue end

        if not plr.Character then continue end

        local visible, part, pos = IsReady(plr.Character)
        if not (visible and part) then continue end

        if DistanceCheckEnabled then
            local dist = getDistance(plr)
            if dist > MaxDistance then continue end
        end

        -- ── WALL CHECK para Aimbot (NUEVO) ────────────────────────────────
        -- Solo se ejecuta si el toggle está activo. Si el objetivo está
        -- detrás de una pared, se salta este jugador. El resto del aimbot
        -- (smoothness, prediction, FOV, sticky lock) no se toca en absoluto.
        if WallCheckEnabled then
            if not HasLineOfSight(part) then
                continue  -- Detrás de pared, ignoramos este objetivo
            end
        end
        -- ─────────────────────────────────────────────────────────────────

        local screenPos = Vector2.new(pos.X, pos.Y)
        local dist      = (screenPos - mousePos).Magnitude

        table.insert(validTargets, {part = part, distance = dist})

        if dist < shortest and dist <= MouseFOV then
            shortest = dist
            closest  = part
        end
    end

    -- Sticky lock
    if stickyLock and currentTarget and currentTarget.Parent then
        local stillValid = false
        for _, t in pairs(validTargets) do
            if t.part == currentTarget then stillValid = true break end
        end
        if stillValid then
            closest = currentTarget
        else
            stickyLock    = false
            currentTarget = nil
        end
    end

    if closest and closest.Parent then
        if currentTarget ~= closest then
            currentTarget  = closest
            targetLockTime = tick()
            stickyLock     = true
        end

        if getfenv().mousemoverel then
            local targetPos = PredictPosition(closest)
            local screen, onScreen = Camera:WorldToViewportPoint(targetPos)

            if onScreen and screen.Z > 0 then
                local screenPos = Vector2.new(screen.X, screen.Y)
                local distance  = (screenPos - mousePos).Magnitude

                if distance > 1 then
                    local smooth = MouseSmoothness * (distance < 50 and 1.5 or 1)
                    local dx = (screen.X - mousePos.X) / smooth
                    local dy = (screen.Y - mousePos.Y) / smooth

                    if math.abs(dx) < 200 and math.abs(dy) < 200 then
                        getfenv().mousemoverel(dx, dy)
                    else
                        currentTarget = nil
                        stickyLock    = false
                    end
                end
            else
                if tick() - targetLockTime > 0.5 then
                    currentTarget = nil
                    stickyLock    = false
                end
            end
        end
    else
        currentTarget = nil
        stickyLock    = false
    end
end)
