-- ── Helpers ───────────────────────────────────────────────────────────────
local function getRainbowColor()
    return Color3.fromHSV((tick() * 0.4) % 1, 1, 1)
end

local function getESPColor(player)
    if RainbowMode then return getRainbowColor() end
    if TeamCheckEnabled and player.Team and LocalPlayer.Team then
        return player.Team == LocalPlayer.Team and TeamColor or EnemyColor
    end
    return ESPColor
end

local function isEnemy(player)
    if not TeamCheckEnabled then return true end
    if not player.Team or not LocalPlayer.Team then return true end
    return player.Team ~= LocalPlayer.Team
end

local function getDistance(player)
    local lc = LocalPlayer.Character
    local pc = player.Character
    if not lc or not pc then return math.huge end
    local lhrp = lc:FindFirstChild("HumanoidRootPart")
    local phrp = pc:FindFirstChild("HumanoidRootPart")
    if not lhrp or not phrp then return math.huge end
    return (lhrp.Position - phrp.Position).Magnitude
end

local function getHealth(player)
    if not player.Character then return 0, 100 end
    local hum = player.Character:FindFirstChild("Humanoid")
    if not hum then return 0, 100 end
    return hum.Health, hum.MaxHealth
end

-- ── WALL CHECK FUNCTION (NUEVO) ───────────────────────────────────────────
-- Lanza un rayo desde el LocalPlayer hasta la parte objetivo.
-- Retorna TRUE si hay línea de visión limpia (sin paredes).
-- Retorna FALSE si hay una pared/obstáculo en el camino.
local function HasLineOfSight(targetPart)
    -- Necesitamos el personaje local para saber desde dónde disparar el rayo
    local localChar = LocalPlayer.Character
    if not localChar or not targetPart or not targetPart.Parent then
        return false
    end

    local origin = localChar:FindFirstChild("HumanoidRootPart")
    if not origin then return false end

    local startPos  = origin.Position
    local targetPos = targetPart.Position
    local direction = (targetPos - startPos)

    -- Lista de partes a ignorar en el raycast:
    -- el propio personaje local + el personaje del objetivo
    local ignoreList = { localChar, targetPart.Parent }

    -- También ignoramos todos los accesorios/herramientas del objetivo
    -- para que no se detecte como "pared" el propio modelo del enemigo
    local ray = Ray.new(startPos, direction)

    -- FindPartOnRayWithIgnoreList ignora todos los descendientes de los modelos
    -- pasados en la lista, lo que evita falsos positivos con el propio personaje
    local hitPart = workspace:FindPartOnRayWithIgnoreList(ray, ignoreList)

    -- Si no golpea nada (nil) → línea de visión limpia
    -- Si golpea algo → hay una pared
    if hitPart == nil then
        return true   -- Línea de visión limpia ✓
    else
        return false  -- Hay obstáculo ✗
    end
end

-- ── Drawings persistentes por jugador ─────────────────────────────────────
local ESPCache = {}

local function newDrawing(type, props)
    local d = Drawing.new(type)
    for k, v in pairs(props) do d[k] = v end
    return d
end

local function createPlayerESP(player)
    local e = {}
    e.Outline    = newDrawing("Square", {Thickness=3,   Filled=false, Visible=false, Color=Color3.new(0,0,0),              Transparency=1})
    e.Box        = newDrawing("Square", {Thickness=1.5, Filled=false, Visible=false, Color=ESPColor,                       Transparency=1})
    e.Tracer     = newDrawing("Line",   {Thickness=1.5,               Visible=false, Color=ESPColor,                       Transparency=1})
    e.NameLabel  = newDrawing("Text",   {Size=14, Font=2, Center=true, Outline=true,  Color=Color3.new(1,1,1),   Visible=false, Transparency=1})
    e.HealthBg   = newDrawing("Square", {Thickness=1,   Filled=true,  Visible=false, Color=Color3.new(0,0,0),              Transparency=0.5})
    e.HealthBar  = newDrawing("Square", {Thickness=1,   Filled=true,  Visible=false, Color=Color3.fromRGB(0,200,0),        Transparency=1})
    e.DistLabel  = newDrawing("Text",   {Size=12, Font=2, Center=true, Outline=true,  Color=Color3.fromRGB(200,200,200), Visible=false, Transparency=1})
    ESPCache[player] = e
end

local function removePlayerESP(player)
    local e = ESPCache[player]
    if not e then return end
    for _, d in pairs(e) do pcall(function() d:Remove() end) end
    ESPCache[player] = nil
end

local function hidePlayerESP(player)
    local e = ESPCache[player]
    if not e then return end
    for _, d in pairs(e) do d.Visible = false end
end

for _, p in pairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then createPlayerESP(p) end
end

Players.PlayerAdded:Connect(function(p)   createPlayerESP(p) end)
Players.PlayerRemoving:Connect(function(p) removePlayerESP(p) end)

