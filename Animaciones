local function updateCanvasSize()
	if not favListFrame then return end
	local count = 0
	for _, child in ipairs(favListFrame:GetChildren()) do
		if child:IsA("Frame") then count += 1 end
	end
	favListFrame.CanvasSize = UDim2.new(0, 0, 0, count * 50 + 10)
end

local function syncEmptyLabel()
	if not favListFrame then return end
	local hasRows = false
	for _, child in ipairs(favListFrame:GetChildren()) do
		if child:IsA("Frame") then hasRows = true break end
	end
	if emptyLabel then
		emptyLabel.Visible = not hasRows
