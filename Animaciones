local EMOTE_PRIORITIES = {
	[Enum.AnimationPriority.Action]  = true,
	[Enum.AnimationPriority.Action2] = true,
	[Enum.AnimationPriority.Action3] = true,
	[Enum.AnimationPriority.Action4] = true,
}

local function isEmoteTrack(track)
	return EMOTE_PRIORITIES[track.Priority] == true
end



local SAVE_FOLDER = "JmodsFavoritos"
local SAVE_FILE   = SAVE_FOLDER .. "/animaciones.json"

local function ensureFolder()
	if not isfolder(SAVE_FOLDER) then
		makefolder(SAVE_FOLDER)
	end
end

local function saveFavoritos()
	ensureFolder()
	local ok, encoded = pcall(function()
		return HttpService:JSONEncode(favoritos)
	end)
	if ok then
		pcall(function() writefile(SAVE_FILE, encoded) end)
	end
end

local function loadFavoritos()
	ensureFolder()
	if not isfile(SAVE_FILE) then return end
	local ok, raw = pcall(function() return readfile(SAVE_FILE) end)
	if not ok or not raw or raw == "" then return end
	local ok2, decoded = pcall(function() return HttpService:JSONDecode(raw) end)
	if ok2 and type(decoded) == "table" then
		favoritos = decoded
	end
end

loadFavoritos()


local function getHumanoid()
	local char = LocalPlayer.Character
	if char then
		return char:FindFirstChildWhichIsA("Humanoid")
	end
	return nil
end

local function getAnimator(Humanoid)
	for i = 1, 10 do
		local animator = Humanoid:FindFirstChildOfClass("Animator")
		if animator then return animator end
		animator = Instance.new("Animator")
		animator.Parent = Humanoid
		task.wait(0.05)
	end
	return nil
end

local function safePlayAnim(animId)
	local humanoid = getHumanoid()
	if not humanoid then return end

	for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
		track:Stop()
	end

	local anim = Instance.new("Animation")
	anim.AnimationId = animId

	for attempt = 1, 5 do
		local animator = getAnimator(humanoid)
		if not animator then
			warn("No se pudo obtener Animator.")
			return
		end
		local success, track = pcall(function()
			return animator:LoadAnimation(anim)
		end)
		if success and track then
			track:Play()
			track:AdjustSpeed(selectedSpeed)
			currentTrack = track
			lastAnimationId = animId
			return
		end
		task.wait(0.1)
	end
	warn("No se pudo cargar la animacion tras varios intentos.")
end

local function playLastAnimation()
	if lastAnimationId then
		safePlayAnim(lastAnimationId)
	end
end

local function stopCurrentAnimation()
	local humanoid = getHumanoid()
	if humanoid then
		for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
			track:Stop()
		end
	end
	currentTrack = nil
end


local externalDetectionConnection = nil
local lastDetectedExternalId = nil

local function startExternalDetection()
	if externalDetectionConnection then return end

	externalDetectionConnection = RunService.Heartbeat:Connect(function()
		local humanoid = getHumanoid()
		if not humanoid then return end

		local playingTracks = humanoid:GetPlayingAnimationTracks()

		for _, track in ipairs(playingTracks) do
			if not isEmoteTrack(track) then continue end

			local animId = track.Animation and track.Animation.AnimationId or ""
			if animId == "" then continue end

			if animId ~= lastDetectedExternalId and animId ~= lastAnimationId then
				lastDetectedExternalId = animId

				local animName = track.Animation and track.Animation.Name or ""
				if animName == "" or animName == "Animation" then
					animName = "[Externo] " .. (animId:match("%d+") or animId)
				end

				lastAnimationId = animId
				lastAnimationName = animName
			end
		end
	end)
end

local function stopExternalDetection()
	if externalDetectionConnection then
		externalDetectionConnection:Disconnect()
		externalDetectionConnection = nil
	end
	lastDetectedExternalId = nil
end


