local function saveCurrentAsFavorite(customName)
	if not lastAnimationId then
		warn("No hay animacion activa para guardar.")
		return
	end

	local name = customName
	if not name or name == "" then
		name = lastAnimationName or ("Anim " .. tostring(#favoritos + 1))
	end

	for _, fav in ipairs(favoritos) do
		if fav.animationid == lastAnimationId then
			warn("Esta animacion ya esta en favoritos: " .. fav.name)
			return
		end
	end

	local newFav = { name = name, animationid = lastAnimationId }
	table.insert(favoritos, newFav)
	saveFavoritos()
	addFavRow(newFav)
end


