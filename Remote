    local function firebaseRequest(method, path, body)
        local url = FIREBASE_URL .. path .. ".json"
        local ok, result = pcall(function()
            local req = {
                Url    = url,
                Method = method,
                Headers = { ["Content-Type"] = "application/json" }
            }
            if body then req.Body = HttpService:JSONEncode(body) end
            return request(req)
        end)
        if ok and result and result.Body and result.Body ~= "" and result.Body ~= "null" then
            local dok, decoded = pcall(function() return HttpService:JSONDecode(result.Body) end)
            if dok then return decoded end
        end
        return nil
    end

