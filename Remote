    -- ========================================
local function CleanupOldData(path)
    local data = firebaseRequest("GET", path)
    if not data or type(data) ~= "table" then return end
    local now = os.time()
    local maxAge = 60
    for key, entry in pairs(data) do
        if type(entry) == "table" then
            if entry.timestamp then
                -- ✅ entrada directa con timestamp (heartbeats, triggers, brings, executions)
                if (now - (entry.timestamp or 0)) > maxAge then
                    firebaseRequest("DELETE", path .. "/" .. key)
                end
            else
                -- ✅ entrada anidada (commands/{serverId}/{cmdKey}) — un nivel más
                local allOld = true
                for subKey, subEntry in pairs(entry) do
                    if type(subEntry) == "table" and subEntry.timestamp then
                        if (now - (subEntry.timestamp or 0)) > maxAge then
                            firebaseRequest("DELETE", path .. "/" .. key .. "/" .. subKey)
                        else
                            allOld = false
                        end
                    end
                end
                -- ✅ si el nodo padre quedó vacío, bórralo también
                if allOld then
                    firebaseRequest("DELETE", path .. "/" .. key)
                end
            end
        end
    end
end
