local function TeleportToServer(link)
            if link == "" or not link:match("placeId=") then
                teleportBtn.Text = "❌ Link inválido"
                teleportBtn.BackgroundColor3 = Color3.fromRGB(220, 80, 80)
                task.wait(1.5)
                teleportBtn.Text = "🚀 Teleportarme"
                teleportBtn.BackgroundColor3 = Color3.fromRGB(88, 101, 242)
                return
            end

            local placeId = link:match("placeId=(%d+)")
            local gameInstanceId = link:match("gameInstanceId=([%w%-]+)")

            if not placeId or not gameInstanceId then
                teleportBtn.Text = "❌ Falta placeId o gameInstanceId"
                teleportBtn.BackgroundColor3 = Color3.fromRGB(220, 80, 80)
                task.wait(1.5)
                teleportBtn.Text = "🚀 Teleportarme"
                teleportBtn.BackgroundColor3 = Color3.fromRGB(88, 101, 242)
                return
            end

            teleportBtn.Text = "⏳ Teleportando..."
            teleportBtn.BackgroundColor3 = Color3.fromRGB(255, 170, 100)

            -- Un solo intento limpio, sin métodos alternativos que se pisen
            local ok, err = pcall(function()
                TeleportService:TeleportToPlaceInstance(tonumber(placeId), gameInstanceId, LocalPlayer)
            end)

            if not ok then
                -- Solo si falló del todo, mostrar error
                teleportBtn.Text = "❌ Error: " .. tostring(err):sub(1, 30)
                teleportBtn.BackgroundColor3 = Color3.fromRGB(220, 80, 80)
                task.wait(2)
                teleportBtn.Text = "🚀 Teleportarme"
                teleportBtn.BackgroundColor3 = Color3.fromRGB(88, 101, 242)
            end
            -- Si ok=true el juego empieza a cargar, no hace falta resetear el botón
        end

