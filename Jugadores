local fg = false
local forceStop = false
local loopFlingTargets = {}
local kaOn = false

local spdVal = 16
local jmpVal = 50

function safeDC(cn)
    if cn then pcall(function() cn:Disconnect() end) end
    return nil
end

function safeChar()
    local c = game.Players.LocalPlayer.Character
    if not c or not c.Parent then return nil, nil, nil end
    return c, c:FindFirstChild("HumanoidRootPart"), c:FindFirstChildOfClass("Humanoid")
end

function predictPosition(targetRoot, lookahead)
    lookahead = lookahead or 0.18
    local vel = targetRoot.AssemblyLinearVelocity
    return targetRoot.Position + vel * lookahead
end

function safeReturnTo(h, hu, originCF, omh, ohh)
    if not h or not h.Parent then return end

    h.Anchored = true
    h.AssemblyLinearVelocity = Vector3.zero
    h.AssemblyAngularVelocity = Vector3.zero
    h.CFrame = originCF

    task.wait(0.05)

    h.CFrame = originCF
    h.AssemblyLinearVelocity = Vector3.zero
    h.AssemblyAngularVelocity = Vector3.zero

    task.wait(0.05)

    h.Anchored = false

    if hu and hu.Parent then
        hu.MaxHealth = omh
        hu.Health = omh
        hu.WalkSpeed = spdVal
        hu.UseJumpPower = true
        hu.JumpPower = jmpVal
        hu.HipHeight = ohh
        hu.PlatformStand = false
        hu.AutoRotate = true
        pcall(function() hu:ChangeState(Enum.HumanoidStateType.GettingUp) end)
    end
end

function fling(t)
    if fg or forceStop then return end
    if not t then
        Rayfield:Notify({Title = "Error", Content = "No hay jugador seleccionado!", Duration = 2, Image = 4483362458})
        return
    end
    local tc = t.Character
    if not tc or not tc.Parent then
        Rayfield:Notify({Title = "Error", Content = "El jugador no tiene personaje!", Duration = 2, Image = 4483362458})
        return
    end

    fg = true
    Rayfield:Notify({Title = "Fling", Content = "Flinging " .. t.DisplayName, Duration = 2, Image = 4483362458})

    task.spawn(function()
        local ok = pcall(function()
            local c, h, hu = safeChar()
            if not h or not hu then fg = false return end

            local originCF = h.CFrame
            local omh = hu.MaxHealth
            local ohh = hu.HipHeight

            local targetStartPos = nil
            local th0 = t.Character and (t.Character:FindFirstChild("HumanoidRootPart") or t.Character:FindFirstChild("Torso"))
            if th0 then targetStartPos = th0.Position end

            local pp, pts = {}, {}

            for _, v in c:GetDescendants() do
                if v:IsA("BasePart") then
                    table.insert(pts, v)
                    pp[v] = {v.CustomPhysicalProperties, v.Massless, v.CanCollide}
                    v.CustomPhysicalProperties = PhysicalProperties.new(9999, 0, 0, 0, 0)
                    v.Massless = false
                elseif v:IsA("BodyMover") or v:IsA("BodyVelocity") or v:IsA("BodyGyro") or
                       v:IsA("BodyPosition") or v:IsA("BodyForce") or v:IsA("LinearVelocity") or
                       v:IsA("AngularVelocity") or v:IsA("AlignPosition") or v:IsA("VectorForce") then
                    pcall(v.Destroy, v)
                end
            end

            local deadStates = {
                Enum.HumanoidStateType.Dead, Enum.HumanoidStateType.FallingDown,
                Enum.HumanoidStateType.Ragdoll, Enum.HumanoidStateType.Physics
            }
            for _, s in ipairs(deadStates) do pcall(function() hu:SetStateEnabled(s, false) end) end

            hu.MaxHealth = math.huge
            hu.Health = math.huge
            local hpC = hu.HealthChanged:Connect(function()
                if hu and hu.Parent then hu.Health = math.huge end
            end)

            hu.WalkSpeed = 0
            hu.JumpPower = 0
            hu.PlatformStand = true
            hu.HipHeight = 0
            hu.AutoRotate = false

            local done, stT, cnt = false, tick(), 0
            local SPD = 9e4
            local successFling = false

            function gt()
                local tc2 = t.Character
                if not tc2 or not tc2.Parent then return nil end
                return tc2:FindFirstChild("HumanoidRootPart") or tc2:FindFirstChild("UpperTorso") or tc2:FindFirstChild("Torso") or tc2:FindFirstChild("Head")
            end

            function td()
                local tc2 = t.Character
                if not tc2 or not tc2.Parent then return true end
                local th = tc2:FindFirstChildOfClass("Humanoid")
                return th and th.Health <= 0
            end

            function df()
                if done or forceStop or not c or not c.Parent or not h or not h.Parent then
                    done = true return
                end
                local th = gt()
                if not th then done = true return end
                if td() then done = true return end

                if targetStartPos and (th.Position - targetStartPos).Magnitude >= 200 then
                    successFling = true
                    done = true
                    return
                end

                cnt = cnt + 1
                local predictedPos = predictPosition(th, 0.18)

                local rz = (math.random() > 0.5 and 1 or -1) * (math.random() * 3 + 0.5)
                local rx = (math.random() - 0.5) * 2
                local ry = (math.random() - 0.5) * 1.5
                if cnt % 3 == 0 then rz, rx, ry = 0, 0, 0 end

                h.CFrame = CFrame.new(predictedPos) * CFrame.new(rx, ry, rz)

                if math.abs(rz) < 1.5 then
                    for _, v in ipairs(pts) do
                        if v and v.Parent then
                            v.AssemblyLinearVelocity = Vector3.new(SPD, SPD, SPD)
                            v.AssemblyAngularVelocity = Vector3.new(SPD, SPD, SPD)
                            v.CanCollide = (v == h)
                        end
                    end
                else
                    for _, v in ipairs(pts) do
                        if v and v.Parent then
                            v.AssemblyLinearVelocity = Vector3.zero
                            v.AssemblyAngularVelocity = Vector3.zero
                            v.CanCollide = false
                        end
                    end
                end
            end

            local c1 = game:GetService("RunService").Stepped:Connect(df)
            local c2 = game:GetService("RunService").Heartbeat:Connect(df)
            local c3 = game:GetService("RunService").RenderStepped:Connect(df)

            repeat task.wait(0.05) until done or forceStop or tick() - stT >= 3

            c1 = safeDC(c1)
            c2 = safeDC(c2)
            c3 = safeDC(c3)
            hpC = safeDC(hpC)

            for _, v in ipairs(pts) do
                pcall(function()
                    if v and v.Parent then
                        v.AssemblyLinearVelocity = Vector3.zero
                        v.AssemblyAngularVelocity = Vector3.zero
                        v.CanCollide = pp[v] and pp[v][3] or true
                    end
                end)
            end

            for pt, pr in pairs(pp) do
                pcall(function()
                    if pt and pt.Parent then
                        pt.CustomPhysicalProperties = pr[1]
                        pt.Massless = pr[2]
                        pt.CanCollide = pr[3]
                    end
                end)
            end

            pcall(function()
                for _, s in ipairs(deadStates) do hu:SetStateEnabled(s, true) end
            end)

            task.wait(0.1)

            safeReturnTo(h, hu, originCF, omh, ohh)

            fg = false

            if not forceStop then
                if successFling then
                    Rayfield:Notify({Title = "Fling", Content = "Eliminado! (+200 studs)", Duration = 2, Image = 4483362458})
                elseif td() then
                    Rayfield:Notify({Title = "Fling", Content = "Eliminado!", Duration = 2, Image = 4483362458})
                else
                    Rayfield:Notify({Title = "Fling", Content = "Flingeado!", Duration = 2, Image = 4483362458})
                end
            end
        end)
        if not ok then
            fg = false
            Rayfield:Notify({Title = "Error", Content = "Fling fallido", Duration = 2, Image = 4483362458})
        end
    end)
end

task.spawn(function()
    while true do
        task.wait(2)
        for plr, _ in pairs(loopFlingTargets) do
            if forceStop then break end
            if plr and plr.Parent and plr.Character and not fg then
                fling(plr)
                repeat task.wait(0.1) until not fg
                task.wait(1)
            end
        end
    end
end)

task.spawn(function()
    while true do
        task.wait(1)
        if kaOn and not fg and not forceStop then
            pcall(function()
                local _, h = safeChar()
                if not h then return end
                for _, p in game.Players:GetPlayers() do
                    if forceStop then break end
                    if p ~= game.Players.LocalPlayer and p.Character then
                        local th = p.Character:FindFirstChild("HumanoidRootPart")
                        if th and (h.Position - th.Position).Magnitude < 20 then
                            fling(p)
                            repeat task.wait(0.1) until not fg
                            task.wait(0.3)
                        end
                    end
                end
            end)
        end
    end
end)

JugadoresTab:CreateSection("Fling")

JugadoresTab:CreateButton({
    Name = "Fling",
    Callback = function()
        if selectedPlayer then
            fling(selectedPlayer)
        else
            Rayfield:Notify({Title = "Error", Content = "Selecciona un jugador primero!", Duration = 2, Image = 4483362458})
        end
    end
})

JugadoresTab:CreateToggle({
    Name = "Loop Fling",
    CurrentValue = false,
    Callback = function(state)
        if not selectedPlayer then
            Rayfield:Notify({Title = "Error", Content = "Selecciona un jugador primero!", Duration = 2, Image = 4483362458})
            return
        end
        if state then
            loopFlingTargets[selectedPlayer] = true
            Rayfield:Notify({Title = "Loop Fling", Content = "Activo: " .. selectedPlayer.Name, Duration = 2, Image = 4483362458})
        else
            loopFlingTargets[selectedPlayer] = nil
            Rayfield:Notify({Title = "Loop Fling", Content = "Apagado: " .. selectedPlayer.Name, Duration = 2, Image = 4483362458})
        end
    end
})

JugadoresTab:CreateButton({
    Name = "Fling a Todos",
    Callback = function()
        Rayfield:Notify({Title = "Fling All", Content = "Mandando a volar a todos...", Duration = 2, Image = 4483362458})
        task.spawn(function()
            for _, p in game.Players:GetPlayers() do
                if forceStop then break end
                if p ~= game.Players.LocalPlayer and p.Character then
                    fling(p)
                    repeat task.wait(0.1) until not fg
                    task.wait(0.5)
                end
            end
            if not forceStop then
                Rayfield:Notify({Title = "Fling All", Content = "Listo!", Duration = 2, Image = 4483362458})
            end
        end)
    end
})

JugadoresTab:CreateToggle({
    Name = "Kill Aura",
    CurrentValue = false,
    Callback = function(state)
        kaOn = state
        Rayfield:Notify({Title = "Kill Aura", Content = state and "Activo" or "Apagado", Duration = 2, Image = 4483362458})
    end
})

JugadoresTab:CreateButton({
    Name = "Detener Fling",
    Callback = function()
        forceStop = true
        kaOn = false
        for k in pairs(loopFlingTargets) do loopFlingTargets[k] = nil end
        Rayfield:Notify({Title = "Force Stop", Content = "Todo detenido!", Duration = 3, Image = 4483362458})
        task.wait(0.5)
        forceStop = false
    end
})

JugadoresTab:CreateButton({
    Name = "Copiar Nombre",
    Callback = function()
        if selectedPlayer then
            pcall(function() setclipboard(selectedPlayer.Name) end)
            Rayfield:Notify({Title = "Copiado", Content = selectedPlayer.Name, Duration = 2, Image = 4483362458})
        else
            Rayfield:Notify({Title = "Error", Content = "Selecciona un jugador primero!", Duration = 2, Image = 4483362458})
        end
    end
})
