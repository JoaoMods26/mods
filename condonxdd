--- Variables de estado de los toggles
local FakePosEnabled = false
local FallBreakerEnabled = false
local HealthMultEnabled = false
local God2018Active = false
local SAFE_OFFSET = Vector3.new(0, 2, 0)

--- Variables de Roblox
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local lp = Players.LocalPlayer

--- Variable para guardar posición segura
