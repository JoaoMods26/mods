--- 🛡️ FUNCIONES ORIGINALES (SIN MODIFICAR)

--- Función God Mode 2018 (original)
local function apply2018GodMode()
    local char = lp.Character or lp.CharacterAdded:Wait()
    local oldHum = char:FindFirstChildOfClass("Humanoid")
    if oldHum then
        oldHum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
        local newHum = oldHum:Clone()
        newHum.Name = "Humanoid"
        newHum.Parent = char
        workspace.CurrentCamera.CameraSubject = newHum
        oldHum.Name = "OldHumanoid"
        oldHum:Destroy()
        local animate = char:FindFirstChild("Animate")
        if animate then
            animate.Disabled = true
            RunService.Stepped:Wait()
            animate.Disabled = false
        end
    end
end

--- Función principal que maneja todos los efectos (original)
local function onChar(char)
    local hrp = char:WaitForChild("HumanoidRootPart")
    local hum = char:WaitForChild("Humanoid")
    lastSafeCF = hrp.CFrame

    -- Main Loop para Fake Position, Health Multiplier y Fall Breaker
    RunService.Heartbeat:Connect(function()
        if not hrp or not hrp.Parent or hum.Health <= 0 then return end
        
        local v = hrp.AssemblyLinearVelocity

        -- 1. FAKE POSITION LOGIC (ORIGINAL)
        if FakePosEnabled then
            -- Anti-Fling (Horizontal)
            if Vector3.new(v.X, 0, v.Z).Magnitude > 60 then
                lastSafeCF = hrp.CFrame
            end

            -- Anti-Fall Damage
            if v.Y < -80 then
                local rayParam = RaycastParams.new()
                rayParam.FilterDescendantsInstances = {char}
                rayParam.FilterType = Enum.RaycastFilterType.Exclude
                local groundCheck = game.Workspace:Raycast(hrp.Position, Vector3.new(0, -15, 0), rayParam)

                if groundCheck then
                    hrp.AssemblyLinearVelocity = Vector3.new(v.X, 0, v.Z) 
                end
            end

            -- Glitch/Void Protection
            if v.Magnitude > 300 then
                hrp.CFrame = lastSafeCF + SAFE_OFFSET
                hrp.AssemblyLinearVelocity = Vector3.zero
            end
        end

        -- 2. HEALTH MULTIPLIER (ORIGINAL)
        if HealthMultEnabled then
            local currentV = hrp.AssemblyLinearVelocity
            hrp.AssemblyLinearVelocity = Vector3.zero
            RunService.RenderStepped:Wait()
            if hrp.Parent then hrp.AssemblyLinearVelocity = currentV end
        end

        -- 3. FALL DAMAGE BREAKER V2 (ORIGINAL)
        if FallBreakerEnabled then
            local currentV = hrp.AssemblyLinearVelocity
            hrp.AssemblyLinearVelocity = Vector3.zero
            RunService.RenderStepped:Wait()
            if hrp.Parent then hrp.AssemblyLinearVelocity = currentV end
        end
    end)
end

--- Conectar eventos de personaje (original)
if lp.Character then onChar(lp.Character) end
lp.CharacterAdded:Connect(function(char)
    onChar(char)
    if God2018Active then task.wait(0.5) apply2018GodMode() end
end)


