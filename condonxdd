ProteTab:CreateToggle({
    Name = "Anti Sit NoTouch",
    CurrentValue = false,
    Callback = function(state)
        AntiSitV4 = state

        if state then
            antiSitLoop4 = RunService.Heartbeat:Connect(function()
                for _,v in ipairs(workspace:GetDescendants()) do
                    if v:IsA("Seat") or v:IsA("VehicleSeat") then
                        if savedSeats[v] == nil then
                            savedSeats[v] = v.CanTouch
                        end

                        v.CanTouch = false
                    end
                end
            end)
        else
            if antiSitLoop4 then
                antiSitLoop4:Disconnect()
                antiSitLoop4 = nil
            end

            for seat,old in pairs(savedSeats) do
                if seat and seat.Parent then
                    seat.CanTouch = old
                end
            end

            table.clear(savedSeats)
        end
    end
})


