task.spawn(function()
    repeat task.wait() until game:IsLoaded()
    repeat task.wait() until _G.AimbotTab

    local Players          = game:GetService("Players")
    local RunService       = game:GetService("RunService")
    local UserInputService = game:GetService("UserInputService")
    local Camera           = workspace.CurrentCamera
    local LocalPlayer      = Players.LocalPlayer
    local AimbotTab        = _G.AimbotTab

    local S = {
        Enabled            = false,
        AimMode            = "Camara",
        AutoAim            = false,
        HoldToAim          = false,
        AimbotPaused       = false,
        FOVRadius          = 300,
        FOVColor           = Color3.fromRGB(255, 165, 0),
        FOVVisible         = true,
        ESPEnabled         = false,
        UseAltESP          = false,
        ESPColor           = Color3.fromRGB(255, 165, 0),
        ESPSize            = 10,
        ShowNPCNames       = true,
        ShowNamesOnly      = false,
        TracersEnabled     = false,
        TracerColor        = Color3.fromRGB(255, 165, 0),
        AimPart            = "Head",
        WallCheck          = false,
        OnlyClose          = false,
        MaxDistance        = 300,
        CamSensitivity     = 5,
        MouseSmoothness    = 3,
        PredictionEnabled  = false,
        PredictionStrength = 0.15,
        RainbowEnabled     = false,
        RainbowSpeed       = 5,
        MaxNPCs            = 200,
        ScanDepth          = 6,
    }

    local PauseKeybind = Enum.KeyCode.Q
    local Holding      = false
    local drawingSupported = false

    local CurrentTarget = nil

    local BLOCKED_STATES = {
        [Enum.HumanoidStateType.Dead]        = true,
        [Enum.HumanoidStateType.FallingDown] = true,
        [Enum.HumanoidStateType.Ragdoll]     = true,
        [Enum.HumanoidStateType.Physics]     = true,
    }

    local function IsNPCApuntable(entry)
        if not entry then return false end
        -- Verificar existencia del modelo y sus partes
        if not entry.model or not entry.model.Parent then return false end
        if not entry.hum   or not entry.hum.Parent   then return false end
        if not entry.hrp   or not entry.hrp.Parent   then return false end
        -- Verificar salud
        if entry.hum.Health <= 0 then return false end
        -- Verificar estado del humanoid
        -- Si esta caido, en ragdoll o muerto: no apuntable
        local ok, state = pcall(function() return entry.hum:GetState() end)
        if ok and BLOCKED_STATES[state] then return false end
        return true
    end

    local function ValidateCurrentTarget()
        if CurrentTarget == nil then return false end
        if IsNPCApuntable(CurrentTarget) then
            return true     -- target valido, mantener
        end
        -- Perdio la condicion: soltar target
        CurrentTarget = nil
        return false
    end

    pcall(function()
        local t = Drawing.new("Circle"); t:Remove()
        drawingSupported = true
    end)

    local FOVCircle
    if drawingSupported then
        pcall(function()
            FOVCircle              = Drawing.new("Circle")
            FOVCircle.Filled       = false
            FOVCircle.Thickness    = 1.5
            FOVCircle.NumSides     = 80
            FOVCircle.Transparency = 1
            FOVCircle.Visible      = false
        end)
    end

    -- =============================================
    local function GetRainbow()
        return Color3.fromHSV((tick() * S.RainbowSpeed / 10) % 1, 1, 1)
    end

    local function ActiveColor()
        return S.RainbowEnabled and GetRainbow() or S.ESPColor
    end

    -- =============================================
    local realPlayerSet = {}

    local function RefreshRealPlayers()
        realPlayerSet = {}
        for _, p in ipairs(Players:GetPlayers()) do
            realPlayerSet[p] = true
            if p.Character then realPlayerSet[p.Character] = true end
        end
    end
    RefreshRealPlayers()
    Players.PlayerAdded:Connect(function() task.wait(0.5); RefreshRealPlayers() end)
    Players.PlayerRemoving:Connect(function() task.wait(0.5); RefreshRealPlayers() end)

    -- =============================================
    local function IsValidNPC(model)
        if not model:IsA("Model")         then return false end
        if realPlayerSet[model]           then return false end
        if model == LocalPlayer.Character then return false end
        local hum = model:FindFirstChildOfClass("Humanoid")
        local hrp = model:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp            then return false end
        if hum.Health <= 0               then return false end
        return true, hum, hrp
    end

    local npcCache       = {}
    local lastNPCRefresh = 0
    local REFRESH_RATE   = 2

    local function ScanContainer(container, result, depth)
        if depth <= 0 then return end
        local ok, children = pcall(function() return container:GetChildren() end)
        if not ok then return end
        for _, obj in ipairs(children) do
            if #result >= S.MaxNPCs then break end
            if obj:IsA("Model") then
                local valid, hum, hrp = IsValidNPC(obj)
                if valid then
                    table.insert(result, {model=obj, hum=hum, hrp=hrp})
                else
                    ScanContainer(obj, result, depth - 1)
                end
            elseif obj:IsA("Folder") then
                ScanContainer(obj, result, depth - 1)
            end
        end
    end

    local function RefreshNPCCache()
        local now = tick()
        if now - lastNPCRefresh < REFRESH_RATE then return end
        lastNPCRefresh = now
        npcCache = {}
        ScanContainer(workspace, npcCache, S.ScanDepth)
    end


    local function GetLiveNPCs()
        local live = {}
        for _, entry in ipairs(npcCache) do
            pcall(function()
                if IsNPCApuntable(entry) then
                    table.insert(live, entry)
                end
            end)
        end
        return live
    end


    local function IsVisible(hrp, targetModel)
        if not S.WallCheck then return true end
        local ok, res = pcall(function()
            local dir = hrp.Position - Camera.CFrame.Position
            local rp  = RaycastParams.new()
            rp.FilterDescendantsInstances = {LocalPlayer.Character, targetModel}
            rp.FilterType  = Enum.RaycastFilterType.Blacklist
            rp.IgnoreWater = true
            local hit = workspace:Raycast(Camera.CFrame.Position, dir, rp)
            return hit == nil or targetModel:IsAncestorOf(hit.Instance)
        end)
        return ok and res
    end

    local function GetClosestNPC(liveNPCs)
        if not LocalPlayer.Character then return nil end
        local myHRP = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not myHRP then return nil end

        -- Target actual sigue vivo y de pie: mantener
        if ValidateCurrentTarget() then
            return CurrentTarget
        end

        -- Buscar el NPC mas cercano al cursor dentro del FOV
        local mousePos       = UserInputService:GetMouseLocation()
        local best, bestDist = nil, math.huge

        for _, entry in ipairs(liveNPCs) do
            local hrp = entry.hrp

            if S.OnlyClose then
                local wd = (hrp.Position - myHRP.Position).Magnitude
                if wd > S.MaxDistance then continue end
            end

            if not IsVisible(hrp, entry.model) then continue end

            local sp, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            if not onScreen or sp.Z <= 0 then continue end

            local dist = (Vector2.new(sp.X, sp.Y) - mousePos).Magnitude
            if dist >= S.FOVRadius then continue end

            if dist < bestDist then
                bestDist = dist
                best     = entry
            end
        end

        CurrentTarget = best
        return CurrentTarget
    end


    local function PredictPos(entry)
        local part = entry.model:FindFirstChild(S.AimPart) or entry.hrp
        if not S.PredictionEnabled then return part.Position end
        local vel = entry.hrp.AssemblyLinearVelocity or Vector3.new()
        return part.Position + vel * S.PredictionStrength
    end

    UserInputService.InputBegan:Connect(function(i, gp)
        if gp then return end

        if i.UserInputType == Enum.UserInputType.MouseButton2 then
            Holding = true
        end

        if i.UserInputType == Enum.UserInputType.Keyboard then
            if i.KeyCode == PauseKeybind then
                if S.Enabled then
                    S.AimbotPaused = not S.AimbotPaused
                    if S.AimbotPaused then
                        CurrentTarget = nil
                        if FOVCircle then
                            pcall(function() FOVCircle.Visible = false end)
                        end
                    end
                    print("[Aimbot] " .. (S.AimbotPaused and "PAUSADO" or "REANUDADO"))
                end
            end
        end
    end)

    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton2 then
            Holding = false
            CurrentTarget = nil   -- al soltar click, buscar de nuevo al presionar
        end
    end)

   
    local ESPCache       = {}
    local TracerCache    = {}
    local BillboardCache = {}
    local ESPFolder      = Instance.new("Folder", game.CoreGui)
    ESPFolder.Name       = "NPCESP_" .. math.random(1, 99999)

    local function GetESP(model)
        if ESPCache[model] then return ESPCache[model] end
        local box, text
        pcall(function()
            box              = Drawing.new("Square")
            box.Thickness    = 2
            box.Filled       = false
            box.Transparency = 1
            box.Visible      = false
            box.ZIndex       = 1
        end)
        pcall(function()
            text          = Drawing.new("Text")
            text.Size     = 16
            text.Center   = true
            text.Outline  = true
            text.Visible  = false
            text.ZIndex   = 2
        end)
        if box and text then
            ESPCache[model] = {box=box, text=text}
        end
        return ESPCache[model]
    end

    local function GetTracer(model)
        if TracerCache[model] then return TracerCache[model] end
        local line
        pcall(function()
            line              = Drawing.new("Line")
            line.Thickness    = 1.5
            line.Transparency = 1
            line.Visible      = false
            line.ZIndex       = 1
        end)
        if line then TracerCache[model] = {line=line} end
        return TracerCache[model]
    end

    local function HideAllESP()
        for _, c in pairs(ESPCache) do
            pcall(function()
                c.box.Visible  = false
                c.text.Visible = false
            end)
        end
    end

    local function HideAllTracers()
        for _, c in pairs(TracerCache) do
            pcall(function() c.line.Visible = false end)
        end
    end

    local function PruneDeadESP(liveSet)
        for model, cache in pairs(ESPCache) do
            if not liveSet[model] then
                pcall(function() cache.box:Remove(); cache.text:Remove() end)
                ESPCache[model] = nil
            end
        end
        for model, cache in pairs(TracerCache) do
            if not liveSet[model] then
                pcall(function() cache.line:Remove() end)
                TracerCache[model] = nil
            end
        end
    end

    local function ClearBillboards()
        for _, bb in pairs(BillboardCache) do
            pcall(function() if bb and bb.Parent then bb:Destroy() end end)
        end
        BillboardCache = {}
    end

    local function CreateBillboard(entry)
        local model = entry.model
        local hrp   = entry.hrp
        if BillboardCache[model] and BillboardCache[model].Parent then return end

        local bb            = Instance.new("BillboardGui")
        bb.Adornee          = hrp
        bb.Size             = UDim2.new(4, 0, 5, 0)
        bb.StudsOffset      = Vector3.new(0, 1, 0)
        bb.AlwaysOnTop      = true
        bb.ResetOnSpawn     = false
        bb.Parent           = ESPFolder

        local f                  = Instance.new("Frame", bb)
        f.Size                   = UDim2.new(1, 0, 1, 0)
        f.BackgroundTransparency = 1

        local col = ActiveColor()
        local function mkBorder(p, s)
            local b            = Instance.new("Frame", f)
            b.Position         = p
            b.Size             = s
            b.BackgroundColor3 = col
            b.BorderSizePixel  = 0
        end
        mkBorder(UDim2.new(0, 0, 0, 0),   UDim2.new(1, 0, 0, 2))
        mkBorder(UDim2.new(0, 0, 1, -2),  UDim2.new(1, 0, 0, 2))
        mkBorder(UDim2.new(0, 0, 0, 0),   UDim2.new(0, 2, 1, 0))
        mkBorder(UDim2.new(1, -2, 0, 0),  UDim2.new(0, 2, 1, 0))

        local lbl                  = Instance.new("TextLabel", f)
        lbl.Size                   = UDim2.new(1, 0, 0, 20)
        lbl.Position               = UDim2.new(0, 0, -0.15, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text                   = S.ShowNPCNames and model.Name or "NPC"
        lbl.TextColor3             = col
        lbl.TextStrokeTransparency = 0.5
        lbl.Font                   = Enum.Font.SourceSansBold
        lbl.TextSize               = 14

        BillboardCache[model] = bb
    end


    -- =============================================
    local lastAimFrame = tick()
    local lastESPFrame = tick()
    local idleSkip     = 0

    RunService.RenderStepped:Connect(function()
        local now = tick()

        RefreshNPCCache()

        local anyActive = S.Enabled or S.ESPEnabled or S.TracersEnabled or S.UseAltESP

        if not anyActive then
            idleSkip += 1
            if idleSkip >= 30 then
                HideAllESP(); HideAllTracers()
                CurrentTarget = nil
                idleSkip = 0
            end
            return
        end
        idleSkip = 0

        local col      = ActiveColor()
        local liveNPCs = GetLiveNPCs()

        local liveSet = {}
        for _, e in ipairs(liveNPCs) do liveSet[e.model] = true end

        -- ============ AIMBOT 
        if now - lastAimFrame >= 0.016 then
            lastAimFrame = now

            -- FOV CIRCLE
            if drawingSupported and FOVCircle then
                local aimbotActivo = S.Enabled and not S.AimbotPaused
                local showFOV      = aimbotActivo and S.FOVVisible and (Holding or S.AutoAim)
                if showFOV then
                    local mp = UserInputService:GetMouseLocation()
                    FOVCircle.Position = Vector2.new(mp.X, mp.Y)
                    FOVCircle.Radius   = S.FOVRadius
                    FOVCircle.Color    = S.RainbowEnabled and GetRainbow() or S.FOVColor
                    FOVCircle.Visible  = true
                else
                    FOVCircle.Visible = false
                end
            end

            -- AIMBOT
            if S.Enabled and not S.AimbotPaused and (Holding or S.AutoAim) then
                local entry = GetClosestNPC(liveNPCs)
                if entry then
                    local predictedPos = PredictPos(entry)

                    if S.AimMode == "Mouse" then
                        if getfenv and getfenv().mousemoverel then
                            local screen, onScreen = Camera:WorldToViewportPoint(predictedPos)
                            if onScreen and screen.Z > 0 then
                                local mp = UserInputService:GetMouseLocation()
                                local dx = (screen.X - mp.X) / math.max(S.MouseSmoothness, 0.1)
                                local dy = (screen.Y - mp.Y) / math.max(S.MouseSmoothness, 0.1)
                                if math.abs(dx) < 300 and math.abs(dy) < 300 then
                                    getfenv().mousemoverel(dx, dy)
                                end
                            end
                        end
                    else
                        pcall(function()
                            local cur   = Camera.CFrame
                            local tgt   = CFrame.new(cur.Position, predictedPos)
                            local alpha = S.CamSensitivity <= 0
                                and 1
                                or math.clamp(0.05 + S.CamSensitivity / 100, 0.05, 1)
                            Camera.CFrame = cur:Lerp(tgt, alpha)
                        end)
                    end
                end
            end
        end

        -- ============ ESP 
        if now - lastESPFrame < 0.033 then return end
        lastESPFrame = now

        PruneDeadESP(liveSet)

        if drawingSupported and S.ESPEnabled and not S.UseAltESP then
            HideAllESP()
            for _, entry in ipairs(liveNPCs) do
                local hrp   = entry.hrp
                local model = entry.model
                local sp, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                if not onScreen or sp.Z <= 0 then continue end

                local scale = 1000 / (sp.Z * 10)
                local h     = math.clamp(scale * S.ESPSize, 20, 400)
                local w     = h / 1.5
                local pos   = Vector2.new(sp.X - w/2, sp.Y - h/2)
                local sz    = Vector2.new(w, h)

                local cache = GetESP(model)
                if not cache then continue end

                pcall(function()
                    if S.ShowNamesOnly then
                        cache.box.Visible = false
                    else
                        cache.box.Color    = col
                        cache.box.Size     = sz
                        cache.box.Position = pos
                        cache.box.Visible  = true
                    end
                    cache.text.Text     = S.ShowNPCNames and model.Name or "NPC"
                    cache.text.Color    = col
                    cache.text.Position = Vector2.new(pos.X + sz.X/2, pos.Y - 20)
                    cache.text.Visible  = true
                end)
            end
        elseif not S.ESPEnabled then
            HideAllESP()
        end

        if S.UseAltESP then
            for _, entry in ipairs(liveNPCs) do
                CreateBillboard(entry)
            end
            for model, bb in pairs(BillboardCache) do
                if not liveSet[model] then
                    pcall(function() if bb and bb.Parent then bb:Destroy() end end)
                    BillboardCache[model] = nil
                end
            end
        else
            if next(BillboardCache) then ClearBillboards() end
        end

        if drawingSupported and S.TracersEnabled then
            HideAllTracers()
            local tracerCol    = S.RainbowEnabled and GetRainbow() or S.TracerColor
            local screenCenter = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)

            for _, entry in ipairs(liveNPCs) do
                local sp, onScreen = Camera:WorldToViewportPoint(entry.hrp.Position)
                if not onScreen or sp.Z <= 0 then continue end

                local cache = GetTracer(entry.model)
                if not cache then continue end

                pcall(function()
                    cache.line.Color   = tracerCol
                    cache.line.From    = screenCenter
                    cache.line.To      = Vector2.new(sp.X, sp.Y)
                    cache.line.Visible = true
                end)
            end
        elseif not S.TracersEnabled then
            HideAllTracers()
        end
    end)

    -- =============================================
 
    AimbotTab:CreateSection("Aimbot NPCs")

    AimbotTab:CreateToggle({
        Name = "Activar Aimbot",
        CurrentValue = false,
        Callback = function(v)
            S.Enabled = v
            if not v then
                S.AimbotPaused = false
                CurrentTarget  = nil
            end
        end
    })

    AimbotTab:CreateKeybind({
        Name = "Tecla Pausa / Reanudar Aimbot",
        CurrentKeybind = "Q",
        Hold = false,
        Callback = function(keybind)
            if typeof(keybind) == "EnumItem" then
                PauseKeybind = keybind
            elseif typeof(keybind) == "string" then
                local ok, kc = pcall(function() return Enum.KeyCode[keybind] end)
                if ok and kc then PauseKeybind = kc end
            end
        end
    })

    AimbotTab:CreateToggle({
        Name = "Auto Apuntar",
        CurrentValue = false,
        Callback = function(v)
            S.AutoAim = v
            if not v then CurrentTarget = nil end
        end
    })

    AimbotTab:CreateDropdown({
        Name = "Modo Aimbot",
        Options = {"Camara", "Mouse"},
        CurrentOption = "Camara",
        Callback = function(v)
            S.AimMode     = v
            CurrentTarget = nil
        end
    })

    AimbotTab:CreateSection("FOV")

    AimbotTab:CreateToggle({
        Name = "Mostrar FOV",
        CurrentValue = true,
        Callback = function(v) S.FOVVisible = v end
    })

    AimbotTab:CreateSlider({
        Name = "Tamano FOV",
        Range = {10, 1000},
        Increment = 5,
        CurrentValue = S.FOVRadius,
        Callback = function(v) S.FOVRadius = v end
    })

    AimbotTab:CreateColorPicker({
        Name = "Color FOV",
        Color = S.FOVColor,
        Callback = function(v) S.FOVColor = v end
    })

    AimbotTab:CreateSection("Modo Camara")

    AimbotTab:CreateSlider({
        Name = "Sensibilidad Camara",
        Range = {0, 100},
        Increment = 1,
        CurrentValue = S.CamSensitivity,
        Callback = function(v) S.CamSensitivity = v end
    })

    AimbotTab:CreateSection("Modo Mouse")

    AimbotTab:CreateSlider({
        Name = "Suavizado Mouse",
        Range = {1, 20},
        Increment = 1,
        CurrentValue = S.MouseSmoothness,
        Callback = function(v) S.MouseSmoothness = v end
    })

    AimbotTab:CreateSection("Target")

    AimbotTab:CreateDropdown({
        Name = "Parte a Apuntar",
        Options = {"Head", "HumanoidRootPart", "Torso", "UpperTorso"},
        CurrentOption = "Head",
        Callback = function(v) S.AimPart = v end
    })

    AimbotTab:CreateToggle({
        Name = "Verificar Paredes",
        CurrentValue = false,
        Callback = function(v) S.WallCheck = v end
    })

    AimbotTab:CreateToggle({
        Name = "Solo NPCs Cercanos",
        CurrentValue = false,
        Callback = function(v) S.OnlyClose = v end
    })

    AimbotTab:CreateSlider({
        Name = "Distancia Maxima",
        Range = {10, 1000},
        Increment = 10,
        CurrentValue = S.MaxDistance,
        Callback = function(v) S.MaxDistance = v end
    })

    AimbotTab:CreateSection("Prediccion")

    AimbotTab:CreateToggle({
        Name = "Activar Prediccion",
        CurrentValue = false,
        Callback = function(v) S.PredictionEnabled = v end
    })

    AimbotTab:CreateSlider({
        Name = "Fuerza de Prediccion",
        Range = {1, 50},
        Increment = 1,
        CurrentValue = 15,
        Callback = function(v) S.PredictionStrength = v / 100 end
    })

    AimbotTab:CreateSection("ESP y Visuals")

    AimbotTab:CreateToggle({
        Name = "ESP NPCs",
        CurrentValue = false,
        Callback = function(v)
            S.ESPEnabled = v
            if not v then HideAllESP() end
        end
    })

    AimbotTab:CreateToggle({
        Name = "ESP Alternativo (Billboard)",
        CurrentValue = false,
        Callback = function(v)
            S.UseAltESP = v
            if not v then ClearBillboards() end
        end
    })

    AimbotTab:CreateToggle({
        Name = "Tracers",
        CurrentValue = false,
        Callback = function(v)
            S.TracersEnabled = v
            if not v then HideAllTracers() end
        end
    })

    AimbotTab:CreateToggle({
        Name = "Mostrar Nombres",
        CurrentValue = true,
        Callback = function(v) S.ShowNPCNames = v end
    })

    AimbotTab:CreateToggle({
        Name = "Solo Nombres",
        CurrentValue = false,
        Callback = function(v) S.ShowNamesOnly = v end
    })

    AimbotTab:CreateColorPicker({
        Name = "Color ESP y Tracers",
        Color = S.ESPColor,
        Callback = function(v)
            S.ESPColor    = v
            S.TracerColor = v
        end
    })

    AimbotTab:CreateSlider({
        Name = "Tamano ESP",
        Range = {2, 30},
        Increment = 1,
        CurrentValue = S.ESPSize,
        Callback = function(v) S.ESPSize = v end
    })

    AimbotTab:CreateSection("Extras")

    AimbotTab:CreateToggle({
        Name = "Rainbow",
        CurrentValue = false,
        Callback = function(v) S.RainbowEnabled = v end
    })

    AimbotTab:CreateSlider({
        Name = "Velocidad Rainbow",
        Range = {1, 20},
        Increment = 1,
        CurrentValue = S.RainbowSpeed,
        Callback = function(v) S.RainbowSpeed = v end
    })

    AimbotTab:CreateSlider({
        Name = "Limite de NPCs",
        Range = {10, 500},
        Increment = 10,
        CurrentValue = S.MaxNPCs,
        Callback = function(v) S.MaxNPCs = v end
    })

    AimbotTab:CreateSlider({
        Name = "Profundidad de Busqueda",
        Range = {1, 10},
        Increment = 1,
        CurrentValue = S.ScanDepth,
        Callback = function(v) S.ScanDepth = v end
    })


end)
