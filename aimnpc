task.spawn(function()
    repeat task.wait() until game:IsLoaded()
    repeat task.wait() until _G.AimbotTab

    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local UserInputService = game:GetService("UserInputService")
    local Camera = workspace.CurrentCamera
    local LocalPlayer = Players.LocalPlayer
    local AimbotTab = _G.AimbotTab

    AimbotTab:CreateSection("Aimbot NPCs - Mouse/Cámara")

    -- ===== CONFIGURACIÓN =====
    local Settings = {
        Enabled          = false,
        AutoAim          = false,
        UseMouseMode     = false,   -- NUEVO: false = modo cámara, true = modo mouse
        FOVRadius        = 300,
        FOVColor         = Color3.fromRGB(255, 165, 0),
        FOVVisible       = true,
        ESPEnabled       = false,
        ESPColor         = Color3.fromRGB(255, 165, 0),
        ESPSize          = 10,
        ShowNPCNames     = true,
        ShowNamesOnly    = false,
        TracersEnabled   = false,
        TracerColor      = Color3.fromRGB(255, 165, 0),
        AimPart          = "Head",
        WallCheck        = false,
        OnlyClose        = false,
        MaxDistance      = 150,
        Sensitivity      = 5,       -- Para modo cámara
        MouseSmoothness  = 3,       -- Para modo mouse
        PredictionEnabled = false,
        PredictionStrength = 0.15,
        RainbowEnabled   = false,
        RainbowSpeed     = 5,
        MaxNPCs          = 50,
        UseAltESP        = false,
    }

    local Holding = false
    local drawingSupported = false

    -- ===== VERIFICAR DRAWING =====
    pcall(function()
        local t = Drawing.new("Circle")
        t:Remove()
        drawingSupported = true
    end)

    -- ===== FOV CIRCLE =====
    local FOVCircle
    if drawingSupported then
        pcall(function()
            FOVCircle = Drawing.new("Circle")
            FOVCircle.Filled = false
            FOVCircle.Thickness = 1.5
            FOVCircle.NumSides = 80
            FOVCircle.Transparency = 1
            FOVCircle.Visible = false
        end)
    end

    -- ===== RAINBOW =====
    local function GetRainbow()
        return Color3.fromHSV((tick() * Settings.RainbowSpeed / 10) % 1, 1, 1)
    end

    -- ===== CACHE DE JUGADORES REALES =====
    local realPlayers = {}
    local function RefreshRealPlayers()
        realPlayers = {}
        for _, p in pairs(Players:GetPlayers()) do
            realPlayers[p.Name] = true
            if p.Character then realPlayers[p.Character.Name] = true end
        end
    end
    RefreshRealPlayers()

    Players.PlayerAdded:Connect(RefreshRealPlayers)
    Players.PlayerRemoving:Connect(function()
        task.wait(0.1)
        RefreshRealPlayers()
    end)

    -- ===== CACHE DE NPCs (se refresca cada 2 segundos, no cada frame) =====
    local npcCache = {}
    local lastNPCRefresh = 0
    local NPC_REFRESH_INTERVAL = 2 -- segundos

    local function IsValidNPC(model)
        if not model:IsA("Model") then return false end
        local hum = model:FindFirstChildOfClass("Humanoid")
        local hrp = model:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp then return false end
        if hum.Health <= 0 then return false end
        if model == LocalPlayer.Character then return false end
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character == model then return false end
        end
        if realPlayers[model.Name] then return false end
        return true
    end

    local function SearchWorkspace(container, result, count)
        for _, obj in pairs(container:GetChildren()) do
            if count[1] >= Settings.MaxNPCs then break end
            if obj:IsA("Model") and IsValidNPC(obj) then
                table.insert(result, obj)
                count[1] = count[1] + 1
            end
            if obj:IsA("Folder") or obj:IsA("Model") then
                SearchWorkspace(obj, result, count)
            end
        end
    end

    local function RefreshNPCCache()
        local now = tick()
        if now - lastNPCRefresh < NPC_REFRESH_INTERVAL then return end
        lastNPCRefresh = now
        npcCache = {}
        local count = {0}
        SearchWorkspace(workspace, npcCache, count)
    end

    -- Llamada inicial
    task.delay(1, RefreshNPCCache)

    -- ===== VISIBILIDAD (wall check) =====
    local function IsVisible(targetChar)
        if not Settings.WallCheck then return true end
        local hrp = targetChar:FindFirstChild("HumanoidRootPart")
        if not hrp then return false end
        local ok, res = pcall(function()
            local dir = (hrp.Position - Camera.CFrame.Position)
            local rp = RaycastParams.new()
            rp.FilterDescendantsInstances = {LocalPlayer.Character, targetChar}
            rp.FilterType = Enum.RaycastFilterType.Blacklist
            rp.IgnoreWater = true
            local hit = workspace:Raycast(Camera.CFrame.Position, dir, rp)
            return hit == nil or targetChar:IsAncestorOf(hit.Instance)
        end)
        return ok and res
    end

    -- ===== OBTENER NPC MÁS CERCANO =====
    local function GetClosestNPC()
        if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return nil end
        local mousePos = UserInputService:GetMouseLocation()
        local closest, bestDist = nil, math.huge

        for _, npc in pairs(npcCache) do
            -- Validar que siga vivo (cache puede tener NPCs muertos)
            local hum = npc:FindFirstChildOfClass("Humanoid")
            local hrp = npc:FindFirstChild("HumanoidRootPart")
            if not hum or not hrp or hum.Health <= 0 then continue end
            if not IsVisible(npc) then continue end

            local sp, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            if not onScreen then continue end

            local dist = (Vector2.new(sp.X, sp.Y) - mousePos).Magnitude
            if dist >= Settings.FOVRadius then continue end

            if Settings.OnlyClose then
                local wd = (hrp.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                if wd > Settings.MaxDistance then continue end
            end

            if dist < bestDist then
                bestDist = dist
                closest = npc
            end
        end
        return closest
    end

    -- ===== INPUT =====
    UserInputService.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton2 then Holding = true end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton2 then Holding = false end
    end)

    -- ===== ESP - CACHE PERSISTENTE (no recrear cada frame) =====
    local ESPCache    = {}  -- key: tostring(model)
    local TracerCache = {}
    local BillboardESPs = {}
    local ESPFolder = Instance.new("Folder", game.CoreGui)
    ESPFolder.Name = "NPCESPFolder_" .. math.random(1,9999)

    local function GetOrCreateESP(key, npcName)
        if ESPCache[key] then return ESPCache[key] end
        local box, text
        pcall(function()
            box = Drawing.new("Square")
            box.Thickness = 2
            box.Filled = false
            box.Transparency = 1
            box.Visible = false
            box.ZIndex = 1
        end)
        pcall(function()
            text = Drawing.new("Text")
            text.Size = 16
            text.Center = true
            text.Outline = true
            text.Visible = false
            text.ZIndex = 2
        end)
        if box and text then
            ESPCache[key] = {box=box, text=text}
        end
        return ESPCache[key]
    end

    local function GetOrCreateTracer(key)
        if TracerCache[key] then return TracerCache[key] end
        local line
        pcall(function()
            line = Drawing.new("Line")
            line.Thickness = 1.5
            line.Transparency = 1
            line.Visible = false
            line.ZIndex = 1
        end)
        if line then TracerCache[key] = {line=line} end
        return TracerCache[key]
    end

    local function HideAllESP()
        for _, c in pairs(ESPCache) do
            pcall(function()
                if c.box  then c.box.Visible  = false end
                if c.text then c.text.Visible = false end
            end)
        end
    end

    local function HideAllTracers()
        for _, c in pairs(TracerCache) do
            pcall(function() if c.line then c.line.Visible = false end end)
        end
    end

    local function ClearBillboards()
        for _, b in pairs(BillboardESPs) do
            pcall(function() if b and b.Parent then b:Destroy() end end)
        end
        BillboardESPs = {}
    end

    local function CreateBillboard(npc)
        local hrp = npc:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local key = tostring(npc)
        if BillboardESPs[key] and BillboardESPs[key].Parent then return end

        local bb = Instance.new("BillboardGui")
        bb.Adornee = hrp
        bb.Size = UDim2.new(4,0,5,0)
        bb.StudsOffset = Vector3.new(0,1,0)
        bb.AlwaysOnTop = true
        bb.ResetOnSpawn = false
        bb.Parent = ESPFolder

        local f = Instance.new("Frame", bb)
        f.Size = UDim2.new(1,0,1,0)
        f.BackgroundTransparency = 1

        local col = Settings.RainbowEnabled and GetRainbow() or Settings.ESPColor
        local function border(pos, sz)
            local b = Instance.new("Frame", f)
            b.Position = pos; b.Size = sz
            b.BackgroundColor3 = col; b.BorderSizePixel = 0
        end
        border(UDim2.new(0,0,0,0),   UDim2.new(1,0,0,2))
        border(UDim2.new(0,0,1,-2),  UDim2.new(1,0,0,2))
        border(UDim2.new(0,0,0,0),   UDim2.new(0,2,1,0))
        border(UDim2.new(1,-2,0,0),  UDim2.new(0,2,1,0))

        local lbl = Instance.new("TextLabel", f)
        lbl.Size = UDim2.new(1,0,0,20)
        lbl.Position = UDim2.new(0,0,-0.15,0)
        lbl.BackgroundTransparency = 1
        lbl.Text = Settings.ShowNPCNames and npc.Name or "NPC"
        lbl.TextColor3 = col
        lbl.TextStrokeTransparency = 0.5
        lbl.Font = Enum.Font.SourceSansBold
        lbl.TextSize = 14

        BillboardESPs[key] = bb
    end

    -- ===== PREDICCIÓN =====
    local function PredictPos(part)
        if not Settings.PredictionEnabled or not part or not part.Parent then return part.Position end
        local hrp = part.Parent:FindFirstChild("HumanoidRootPart")
        if not hrp then return part.Position end
        local vel = hrp.AssemblyLinearVelocity or Vector3.new()
        return part.Position + (vel * Settings.PredictionStrength)
    end

    -- ===== VARIABLES MOUSE MODE =====
    local currentTarget = nil
    local stickyLock = false
    local targetLockTime = 0

    -- ===== LOOP PRINCIPAL =====
    local lastFrame = tick()
    local lastESPFrame = tick()
    local frameSkip = 0

    RunService.RenderStepped:Connect(function()
        local now = tick()

        -- Refrescar cache de NPCs (cada 2s, no cada frame)
        RefreshNPCCache()

        local anyActive = Settings.Enabled or Settings.ESPEnabled
            or Settings.TracersEnabled or Settings.UseAltESP or Settings.RainbowEnabled

        if not anyActive then
            frameSkip += 1
            if frameSkip >= 30 then
                HideAllESP(); HideAllTracers(); frameSkip = 0
            end
            return
        end

        -- Limitar aimbot a ~60fps
        if now - lastFrame < 0.016 then return end
        lastFrame = now

        -- RAINBOW
        local activeColor = Settings.RainbowEnabled and GetRainbow() or Settings.ESPColor
        local tracerCol   = Settings.RainbowEnabled and GetRainbow() or Settings.TracerColor
        local fovCol      = Settings.RainbowEnabled and GetRainbow() or Settings.FOVColor

        -- FOV CIRCLE
        if drawingSupported and FOVCircle then
            local shouldShow = (Holding or Settings.AutoAim) and Settings.Enabled and Settings.FOVVisible
            if shouldShow then
                local mp = UserInputService:GetMouseLocation()
                FOVCircle.Position = Vector2.new(mp.X, mp.Y)
                FOVCircle.Radius = Settings.FOVRadius
                FOVCircle.Color = fovCol
                FOVCircle.Visible = true
            else
                FOVCircle.Visible = false
            end
        end

        -- ===== AIMBOT =====
        if Settings.Enabled and (Holding or Settings.AutoAim) then
            local target = GetClosestNPC()

            if target then
                local aimPart = target:FindFirstChild(Settings.AimPart)
                    or target:FindFirstChild("HumanoidRootPart")

                if aimPart then
                    local predictedPos = PredictPos(aimPart)

                    if Settings.UseMouseMode then
                        -- ===== MODO MOUSE (mousemoverel) =====
                        if getfenv and getfenv().mousemoverel then
                            local screen, onScreen = Camera:WorldToViewportPoint(predictedPos)
                            if onScreen and screen.Z > 0 then
                                local mp = UserInputService:GetMouseLocation()
                                local dx = (screen.X - mp.X) / Settings.MouseSmoothness
                                local dy = (screen.Y - mp.Y) / Settings.MouseSmoothness
                                if math.abs(dx) < 300 and math.abs(dy) < 300 then
                                    getfenv().mousemoverel(dx, dy)
                                end
                            end
                        end
                    else
                        -- ===== MODO CÁMARA =====
                        pcall(function()
                            local cur = Camera.CFrame
                            local tgt = CFrame.new(cur.Position, predictedPos)
                            local alpha = Settings.Sensitivity <= 0
                                and 1
                                or math.clamp(0.1 + Settings.Sensitivity / 100, 0, 1)
                            Camera.CFrame = cur:Lerp(tgt, alpha)
                        end)
                    end
                end
            end
        end

        -- ===== ESP (limitar a 30fps para ahorrar recursos) =====
        if now - lastESPFrame < 0.033 then return end
        lastESPFrame = now

        -- ESP Drawing
        if drawingSupported and Settings.ESPEnabled and not Settings.UseAltESP then
            HideAllESP()

            for _, npc in pairs(npcCache) do
                local hum = npc:FindFirstChildOfClass("Humanoid")
                local hrp = npc:FindFirstChild("HumanoidRootPart")
                if not hum or not hrp or hum.Health <= 0 then continue end

                local sp, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                if not onScreen or sp.Z <= 0 then continue end

                local key = tostring(npc)
                local scale = 1000 / (sp.Z * 10)
                local h = math.clamp(scale * Settings.ESPSize, 20, 400)
                local w = h / 1.5
                local pos = Vector2.new(sp.X - w/2, sp.Y - h/2)
                local sz  = Vector2.new(w, h)

                local cache = GetOrCreateESP(key, npc.Name)
                if cache then
                    pcall(function()
                        if cache.box then
                            if Settings.ShowNamesOnly then
                                cache.box.Visible = false
                            else
                                cache.box.Color = activeColor
                                cache.box.Size = sz
                                cache.box.Position = pos
                                cache.box.Visible = true
                            end
                        end
                        if cache.text then
                            cache.text.Text = Settings.ShowNPCNames and npc.Name or "NPC"
                            cache.text.Color = activeColor
                            cache.text.Position = Vector2.new(pos.X + sz.X/2, pos.Y - 20)
                            cache.text.Visible = true
                        end
                    end)
                end
            end
        end

        -- ESP Alternativo
        if Settings.UseAltESP then
            local active = {}
            for _, npc in pairs(npcCache) do
                local hum = npc:FindFirstChildOfClass("Humanoid")
                local hrp = npc:FindFirstChild("HumanoidRootPart")
                if hum and hrp and hum.Health > 0 then
                    local key = tostring(npc)
                    active[key] = true
                    if not BillboardESPs[key] or not BillboardESPs[key].Parent then
                        CreateBillboard(npc)
                    end
                end
            end
            for key, bb in pairs(BillboardESPs) do
                if not active[key] then
                    pcall(function() if bb and bb.Parent then bb:Destroy() end end)
                    BillboardESPs[key] = nil
                end
            end
        else
            ClearBillboards()
        end

        -- TRACERS
        if drawingSupported and Settings.TracersEnabled then
            HideAllTracers()
            for _, npc in pairs(npcCache) do
                local hum = npc:FindFirstChildOfClass("Humanoid")
                local hrp = npc:FindFirstChild("HumanoidRootPart")
                if not hum or not hrp or hum.Health <= 0 then continue end

                local sp, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                if not onScreen or sp.Z <= 0 then continue end

                local key = tostring(npc)
                local cache = GetOrCreateTracer(key)
                if cache and cache.line then
                    pcall(function()
                        cache.line.Color = tracerCol
                        cache.line.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                        cache.line.To   = Vector2.new(sp.X, sp.Y)
                        cache.line.Visible = true
                    end)
                end
            end
        end
    end)

    -- ===== LIMPIEZA AL SALIR =====
    Players.PlayerRemoving:Connect(function(p)
        if p == LocalPlayer then
            for _, c in pairs(ESPCache) do
                pcall(function()
                    if c.box  then c.box:Remove()  end
                    if c.text then c.text:Remove() end
                end)
            end
            for _, c in pairs(TracerCache) do
                pcall(function() if c.line then c.line:Remove() end end)
            end
            ClearBillboards()
            if FOVCircle then pcall(function() FOVCircle:Remove() end) end
        end
    end)

    -- ===== UI =====
    AimbotTab:CreateToggle({
        Name = "Aimbot NPCs",
        CurrentValue = false,
        Callback = function(v) Settings.Enabled = v end
    })

    AimbotTab:CreateToggle({
        Name = "Auto Apuntar",
        CurrentValue = false,
        Callback = function(v) Settings.AutoAim = v end
    })

    -- NUEVO TOGGLE MODO MOUSE/CAMARA
    AimbotTab:CreateToggle({
        Name = "Modo Mouse (OFF = Modo Cámara)",
        CurrentValue = false,
        Callback = function(v)
            Settings.UseMouseMode = v
        end
    })

    AimbotTab:CreateToggle({
        Name = "Mostrar FOV",
        CurrentValue = true,
        Callback = function(v) Settings.FOVVisible = v end
    })

    AimbotTab:CreateSlider({
        Name = "Tamaño del FOV",
        Range = {10, 1000},
        Increment = 1,
        CurrentValue = Settings.FOVRadius,
        Callback = function(v) Settings.FOVRadius = v end
    })

    AimbotTab:CreateColorPicker({
        Name = "Color del FOV",
        Color = Settings.FOVColor,
        Callback = function(v) Settings.FOVColor = v end
    })

    AimbotTab:CreateSection("Modo Cámara")

    AimbotTab:CreateSlider({
        Name = "Sensibilidad Cámara",
        Range = {0, 100},
        Increment = 1,
        CurrentValue = Settings.Sensitivity,
        Callback = function(v) Settings.Sensitivity = v end
    })

    AimbotTab:CreateSection("Modo Mouse")

    AimbotTab:CreateSlider({
        Name = "Suavizado Mouse",
        Range = {1, 20},
        Increment = 1,
        CurrentValue = Settings.MouseSmoothness,
        Callback = function(v) Settings.MouseSmoothness = v end
    })

    AimbotTab:CreateSection("Target")

    AimbotTab:CreateDropdown({
        Name = "Parte a Apuntar",
        Options = {"Head", "HumanoidRootPart", "Torso", "UpperTorso"},
        CurrentOption = "Head",
        Callback = function(v) Settings.AimPart = v end
    })

    AimbotTab:CreateToggle({
        Name = "Verificar Paredes",
        CurrentValue = false,
        Callback = function(v) Settings.WallCheck = v end
    })

    AimbotTab:CreateToggle({
        Name = "Solo NPCs Cercanos",
        CurrentValue = false,
        Callback = function(v) Settings.OnlyClose = v end
    })

    AimbotTab:CreateSlider({
        Name = "Distancia Máxima",
        Range = {10, 500},
        Increment = 5,
        CurrentValue = Settings.MaxDistance,
        Callback = function(v) Settings.MaxDistance = v end
    })

    AimbotTab:CreateSection("Predicción")

    AimbotTab:CreateToggle({
        Name = "Activar Predicción",
        CurrentValue = false,
        Callback = function(v) Settings.PredictionEnabled = v end
    })

    AimbotTab:CreateSlider({
        Name = "Fuerza de Predicción",
        Range = {1, 50},
        Increment = 1,
        CurrentValue = 15,
        Callback = function(v) Settings.PredictionStrength = v / 100 end
    })

    AimbotTab:CreateSection("ESP & Visuals")

    AimbotTab:CreateToggle({
        Name = "ESP NPCs",
        CurrentValue = false,
        Callback = function(v)
            Settings.ESPEnabled = v
            if not v then HideAllESP() end
        end
    })

    AimbotTab:CreateToggle({
        Name = "ESP Alternativo (Billboard)",
        CurrentValue = false,
        Callback = function(v)
            Settings.UseAltESP = v
            if not v then ClearBillboards() end
        end
    })

    AimbotTab:CreateToggle({
        Name = "Mostrar Nombres NPCs",
        CurrentValue = true,
        Callback = function(v) Settings.ShowNPCNames = v end
    })

    AimbotTab:CreateToggle({
        Name = "Solo Nombres",
        CurrentValue = false,
        Callback = function(v) Settings.ShowNamesOnly = v end
    })

    AimbotTab:CreateColorPicker({
        Name = "Color ESP/Tracers",
        Color = Settings.ESPColor,
        Callback = function(v)
            Settings.ESPColor = v
            Settings.TracerColor = v
        end
    })

    AimbotTab:CreateSlider({
        Name = "Tamaño ESP",
        Range = {2, 30},
        Increment = 1,
        CurrentValue = Settings.ESPSize,
        Callback = function(v) Settings.ESPSize = v end
    })

    AimbotTab:CreateToggle({
        Name = "Tracers",
        CurrentValue = false,
        Callback = function(v)
            Settings.TracersEnabled = v
            if not v then HideAllTracers() end
        end
    })

    AimbotTab:CreateSlider({
        Name = "Límite de NPCs",
        Range = {5, 100},
        Increment = 5,
        CurrentValue = Settings.MaxNPCs,
        Callback = function(v) Settings.MaxNPCs = v end
    })

    AimbotTab:CreateSection("Extras")

    AimbotTab:CreateToggle({
        Name = "Rainbow",
        CurrentValue = false,
        Callback = function(v) Settings.RainbowEnabled = v end
    })

    AimbotTab:CreateSlider({
        Name = "Velocidad Rainbow",
        Range = {1, 20},
        Increment = 1,
        CurrentValue = Settings.RainbowSpeed,
        Callback = function(v) Settings.RainbowSpeed = v end
    })

    print("✅ Aimbot NPCs cargado - Modo Mouse/Cámara disponible")
end)
