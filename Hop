    -- FIX: paginate corta el loop apenas isDestroyed sea true,
    -- en vez de seguir pidiendo páginas para una ventana que ya
    -- no existe.
    local function runFetch(onBatch)
        local servers = {}
        local seenIds = {}
        local hadFailure = false

        local function ingestPage(data)
            local newCount = 0
            if data and data.data then
                for _, server in ipairs(data.data) do
                    if not seenIds[server.id] then
                        seenIds[server.id] = true
                        table.insert(servers, server)
                        newCount += 1
                    end
                end
            end
            return newCount
        end

        local function paginate(sortOrder)
            local cursor = nil
            local pages = 0
            repeat
                if isDestroyed then break end

                local data = fetchServersPage(cursor, sortOrder)
                pages += 1

                if data then
                    local newCount = ingestPage(data)
                    cursor = data.nextPageCursor

                    if onBatch and newCount > 0 and not isDestroyed then
                        onBatch(servers)
                    end
                else
                    hadFailure = true
                    cursor = nil
                end

                if not isDestroyed then
                    task.wait(0.05)
                end
            until not cursor or cursor == "" or pages > 200 or isDestroyed
        end

        paginate("Asc")
        if not isDestroyed then
            paginate("Desc")
        end

        return servers, hadFailure
    end

    local MAX_FULL_RETRIES = 3

    local function refreshServers()
        if isFetching or isDestroyed then return end
        isFetching = true
        setRefreshEnabled(false)

        tween(RefreshBtn, {Rotation = RefreshBtn.Rotation + 360}, 0.6, Enum.EasingStyle.Quad)

        StatusLabel.Text = "🔄 Buscando servidores..."
        StatusLabel.TextColor3 = Theme.SubText
        EmptyState.Visible = true
        EmptyState.Text = "Cargando lista de servidores..."
        allServers = {}
        clearList()

        local function onBatch(cumulativeServers)
            if isDestroyed then return end
            allServers = cumulativeServers
            renderList()
        end

        task.spawn(function()
            local bestServers, bestHadFailure = {}, true

            local ok, errMsg = pcall(function()
                for attempt = 1, MAX_FULL_RETRIES do
                    if isDestroyed then break end

                    if attempt > 1 then
                        StatusLabel.Text = string.format("🔄 Reintentando carga completa (%d/%d)...", attempt, MAX_FULL_RETRIES)
                        allServers = {}
                        clearList()
                    end

                    local servers, hadFailure = runFetch(onBatch)

                    if (not hadFailure and bestHadFailure) or (#servers > #bestServers) then
                        bestServers, bestHadFailure = servers, hadFailure
                    end

                    if not hadFailure or isDestroyed then
                        break
                    end

                    if attempt < MAX_FULL_RETRIES and not isDestroyed then
                        task.wait(0.5 * attempt)
                    end
                end
            end)

            isFetching = false

            -- FIX: si ya se cerró la ventana mientras esto corría,
            -- no tocamos ni un solo elemento de la UI (ya no existen).
            if isDestroyed then return end

            setRefreshEnabled(true)

            if ok then
                allServers = bestServers
                renderList()
                if bestHadFailure then
                    StatusLabel.Text = StatusLabel.Text .. string.format("  (⚠️ carga parcial tras %d intentos, hubo fallos de red)", MAX_FULL_RETRIES)
                end
            else
                warn("[ServerFinder] Error durante la búsqueda: " .. tostring(errMsg))
                if #allServers == 0 then
                    StatusLabel.Text = "❌ Error al buscar servidores (mirá la consola de tu executor)"
                    StatusLabel.TextColor3 = Theme.Danger
                    EmptyState.Visible = true
                    EmptyState.Text = "Ocurrió un error. Probá darle a Refresh de nuevo."
                else
                    renderList()
                    StatusLabel.Text = StatusLabel.Text .. "  (⚠️ se cortó por un error, dale Refresh para reintentar)"
                end
            end
        end)
    end

