            end
        else
            -- Acá está el fix principal: llamamos a la función de
            -- limpieza en vez de solo destruir el ScreenGui. Esto
            -- pone isDestroyed = true y corta el fetch de inmediato.
            if ServerFinderCleanup then
                ServerFinderCleanup()
            end
        end
    end
})
