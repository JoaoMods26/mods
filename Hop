    local MAX_ATTEMPTS_PER_PAGE = 6

    -- FIX: cada intento revisa isDestroyed antes de seguir
    -- esperando/reintentando, así no sigue pegándole a la API
    -- de Roblox después de que cerraste la ventana.
    local function fetchServersPage(cursor, sortOrder)
        sortOrder = sortOrder or "Asc"
        local url = string.format("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=%s&limit=100", game.PlaceId, sortOrder)
        if cursor then
            url = url .. "&cursor=" .. cursor
        end

        for attempt = 1, MAX_ATTEMPTS_PER_PAGE do
            if isDestroyed then return nil end

            local ok, response = pcall(requestFunc, {
                Url = url,
                Method = "GET"
            })

            local statusOk = ok and response and response.Body
                and (response.StatusCode == nil or response.StatusCode == 200)

            if statusOk then
                local success, decoded = pcall(HttpService.JSONDecode, HttpService, response.Body)
                if success and decoded then
                    return decoded
                end
            end

            if attempt < MAX_ATTEMPTS_PER_PAGE and not isDestroyed then
                local isRateLimited = ok and response and response.StatusCode == 429
                local baseWait = isRateLimited and (1.5 * attempt) or (0.35 * attempt)
                local jitter = math.random() * 0.25
                task.wait(baseWait + jitter)
            end
        end

        return nil
    end

    local function setRefreshEnabled(enabled)
        if isDestroyed then return end
        RefreshBtn.Active = enabled
        if enabled then
